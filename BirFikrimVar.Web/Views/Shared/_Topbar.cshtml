@{
    var name = User.Identity?.Name ?? "";
    var initials = name.Length >= 2
        ? name.Substring(0, 2).ToUpper()
        : name.ToUpper();
}

<header class="topbar">
    <button class="topbar-btn d-lg-none me-1 border-0"
            id="sidebarToggle"
            style="font-size:18px; width:34px; height:34px;">
        <i class="bi bi-list"></i>
    </button>

    <div class="topbar-breadcrumb">
        <span class="bc-root">Bir Fikrim Var</span>
        <span class="bc-sep">/</span>
        <span class="bc-current">@(ViewData["PageTitle"] ?? ViewData["Title"] ?? "Sayfa")</span>
    </div>

    <div class="topbar-divider d-none d-md-block"></div>

   

    

    <div class="dropdown">
        <button class="topbar-user" data-bs-toggle="dropdown">
            <div class="topbar-user-avatar">@initials</div>
            <span class="topbar-user-name d-none d-md-inline">@name</span>
            <span class="topbar-user-chevron d-none d-md-inline">▾</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm"
            style="min-width:180px; border-color:#f0f0f0; border-radius:8px; font-size:13px;">
            <li>
                <a class="dropdown-item" asp-controller="Account" asp-action="Profil"
                   style="font-weight:500;">
                    <i class="bi bi-person me-2 text-muted"></i>Profilim
                </a>
            </li>
            <li><hr class="dropdown-divider my-1" style="border-color:#f0f0f0;"></li>
            <li>
                <form asp-controller="Account" asp-action="Cikis" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item"
                            style="color:#dc2626; font-weight:500;">
                        <i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap
                    </button>
                </form>
            </li>
        </ul>
    </div>
</header>