<header class="topbar">
    <button class="topbar-icon-btn border-0 me-2 d-lg-none" id="sidebarToggle" style="font-size:18px; width:36px; height:36px;">
        <i class="bi bi-list"></i>
    </button>

    <div class="topbar-page-title">
        @ViewData["PageTitle"]
        @if (ViewData["BreadcrumbCurrent"] != null)
        {
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-curr">@ViewData["BreadcrumbCurrent"]</span>
        }
    </div>

    <a asp-controller="Home" asp-action="Index" class="topbar-icon-btn d-none d-md-flex">
        <i class="bi bi-search"></i>
    </a>

    <div class="topbar-divider d-none d-md-block"></div>

    <div class="dropdown">
        <button class="topbar-icon-btn position-relative" data-bs-toggle="dropdown">
            <i class="bi bi-bell"></i>
            <span class="topbar-notif-dot"></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm border" style="min-width: 240px; font-size: 13px;">
            <li><h6 class="dropdown-header" style="font-size: 11px;">Bildirimler</h6></li>
            <li>
                <span class="dropdown-item" style="cursor: default; white-space: normal; padding: 8px 16px;">
                    <div style="color: #374151; font-size: 12.5px;">Fikriniz ön onaya gönderildi</div>
                    <div style="color: #9ca3af; font-size: 11px; margin-top: 2px;">2 saat önce</div>
                </span>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li><a class="dropdown-item text-center" style="font-size: 12px; color: #2563eb;" href="#">Tümünü gör</a></li>
        </ul>
    </div>

    <div class="dropdown">
        <button class="topbar-user-btn" data-bs-toggle="dropdown">
            <div class="topbar-avatar">
                @{
                    var name = User.Identity?.Name ?? "";
                    @(name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper())
                }
            </div>
            <span class="topbar-username d-none d-md-inline">@User.Identity?.Name</span>
            <span class="topbar-chevron d-none d-md-inline">▾</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm border" style="min-width: 180px; font-size: 13px;">
            <li>
                <a class="dropdown-item" asp-controller="Account" asp-action="Profil">
                    <i class="bi bi-person me-2 text-muted"></i> Profilim
                </a>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
                <form asp-controller="Account" asp-action="Cikis" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item" style="color: #dc2626;">
                        <i class="bi bi-box-arrow-left me-2"></i> Çıkış Yap
                    </button>
                </form>
            </li>
        </ul>
    </div>
</header>