@{
    var name = User.Identity?.Name ?? "Kullanıcı";
    var initials = name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Aktiflik kontrolü: Hem controller hem action tam eşleşmeli
    string IsActive(string c, string a)
        => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
           string.Equals(action, a, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<div class="lp-sidebar">
    @* --- BRAND / LOGO AREA --- *@
    <a asp-controller="Home" asp-action="Index" class="lp-sidebar-brand">
        <img src="~/imgs/BirFikrimVar.png" alt="Logo" class="lp-sb-logo" />
        <span class="lp-sb-name">Bir Fikrim Var</span>
    </a>

    @* --- NAVIGATION --- *@
    <nav class="lp-sidebar-menu">
        <div class="lp-menu-section">
            <p class="lp-menu-label">Genel</p>
            <a asp-controller="Home" asp-action="Index" class="lp-menu-link @IsActive("Home", "Index")">
                <i class="bi bi-grid-1x2"></i> <span>Dashboard</span>
            </a>
            <a asp-controller="Account" asp-action="Profil" class="lp-menu-link @IsActive("Account", "Profil")">
                <i class="bi bi-person-circle"></i> <span>Kullanıcı Bilgileri</span>
            </a>
        </div>

        @if (!User.IsInRole("OnOnayci") && !User.IsInRole("KomisyonUyesi") || User.IsInRole("Admin"))
        {
            <div class="lp-menu-section">
                <p class="lp-menu-label">Başvurular</p>
                <a asp-controller="Ideas" asp-action="Index" class="lp-menu-link @IsActive("Ideas", "Index")">
                    <i class="bi bi-collection"></i> <span>Fikirlerim</span>
                </a>
                <a asp-controller="Ideas" asp-action="Olustur" class="lp-menu-link @IsActive("Ideas", "Olustur")">
                    <i class="bi bi-plus-square"></i> <span>Yeni Fikir</span>
                </a>
            </div>
        }

        @if (User.IsInRole("OnOnayci") || User.IsInRole("KomisyonUyesi") || User.IsInRole("Admin"))
        {
            <div class="lp-menu-section">
                <p class="lp-menu-label">Değerlendirme</p>
                @if (User.IsInRole("OnOnayci") || User.IsInRole("Admin"))
                {
                    <a asp-controller="Approval" asp-action="PreApprovalList" class="lp-menu-link @IsActive("Approval", "PreApprovalList")">
                        <i class="bi bi-ui-checks"></i> <span>Ön Onay Paneli</span>
                    </a>
                }
                @if (User.IsInRole("KomisyonUyesi") || User.IsInRole("Admin"))
                {
                    <a asp-controller="Approval" asp-action="CommissionList" class="lp-menu-link @IsActive("Approval", "CommissionList")">
                        <i class="bi bi-award"></i> <span>Komisyon Paneli</span>
                    </a>
                }
            </div>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="lp-menu-section">
                <p class="lp-menu-label">Yönetim</p>
                <a asp-controller="Admin" asp-action="AllIdeas" class="lp-menu-link @IsActive("Admin", "AllIdeas")">
                    <i class="bi bi-inboxes"></i> <span>Tüm Fikirler</span>
                </a>
                <a asp-controller="Admin" asp-action="Users" class="lp-menu-link @IsActive("Admin", "Users")">
                    <i class="bi bi-people"></i> <span>Kullanıcı Yönetimi</span>
                </a>
                <a asp-controller="Admin" asp-action="Categories" class="lp-menu-link @IsActive("Admin", "Categories")">
                    <i class="bi bi-tags"></i> <span>Kategori Yönetimi</span>
                </a>
                <a asp-controller="Admin" asp-action="Logs" class="lp-menu-link @IsActive("Admin", "Logs")">
                    <i class="bi bi-terminal"></i> <span>Sistem Logları</span>
                </a>
            </div>
        }
    </nav>

    @* --- FOOTER / USER --- *@
    <div class="lp-sidebar-footer">
        <div class="lp-user-box">
            <div class="lp-user-avatar">@initials</div>
            <div class="lp-user-meta">
                <span class="lp-user-name">@name</span>
                <span class="lp-user-role">
                    @(User.IsInRole("Admin") ? "Yönetici" : User.IsInRole("OnOnayci") ? "Ön Onaycı" : User.IsInRole("KomisyonUyesi") ? "Komisyon" : "Kullanıcı")
                </span>
            </div>
        </div>

        <form asp-controller="Account" asp-action="Cikis" method="post" id="actualLogoutForm" style="display:none;">
            @Html.AntiForgeryToken()
        </form>
        <button type="button" class="lp-logout-btn" data-bs-toggle="modal" data-bs-target="#logoutModal">
            <i class="bi bi-box-arrow-left"></i>
        </button>
    </div>
</div>