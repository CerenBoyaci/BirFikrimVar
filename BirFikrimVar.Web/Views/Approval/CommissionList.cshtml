@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Komisyon Paneli";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-info text-dark">
        <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Komisyon Onayı Bekleyen Fikirler</h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Başlık</th>
                        <th>Başvuru Sahibi</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fikir in Model)
                    {
                        <tr>
                            <td>#@fikir.Id</td>
                            <td class="fw-bold">@fikir.Baslik</td>
                            <td>@fikir.BasvuruSahibiAdSoyad</td>
                            <td>@fikir.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="badge bg-info text-dark">@fikir.Durum</span></td>
                            <td class="text-end">
                                <a asp-action="CommissionEvaluate" asp-route-id="@fikir.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-star-fill"></i> Puan Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-secondary text-center border-0 mb-0">
                Şu anda komisyon değerlendirmesi bekleyen bir fikir bulunmamaktadır.
            </div>
        }
    </div>
</div>