@model List<BirFikrimVar.Web.Models.FikirListeViewModel>
<div style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; background: #f9fafb; margin-bottom: 12px; border-radius: 6px;">
    <div class="d-flex align-items-center gap-3">
        <div style="position: relative; flex: 1; max-width: 300px;">
            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #9ca3af;">
                <i class="bi bi-search" style="font-size: 14px;"></i>
            </span>
            <input type="text"
                   id="komisyonAramaInput"
                   class="form-control"
                   placeholder="Başlık veya başvuru sahibi ara..."
                   style="font-size: 13px; border-color: #d1d5db; border-radius: 6px; padding: 6px 12px 6px 32px; width: 100%;"
                   onkeyup="komisyonFiltreleVeSirala()" />
        </div>

        <div style="position: relative; width: 220px;">
            <select id="komisyonDurumFiltre"
                    class="form-select"
                    style="font-size: 13px; border-color: #d1d5db; border-radius: 6px; padding: 6px 12px; width: 100%;"
                    onchange="komisyonFiltreleVeSirala()">
                <option value="TUMU">Tüm Durumlar</option>
                <option value="KomisyonOnayiBekliyor">Puanlama Devam Ediyor</option>
                <option value="KomisyonOnayli">Kabul Edildi</option>
                <option value="KomisyonOnayiRetli">Reddedildi</option>
            </select>
        </div>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <th style="width:60px;">ID</th>
            <th>Başlık</th>
            <th>Başvuru Sahibi</th>
            <th style="width:130px;">Tarih</th>
            <th style="width:140px;">Durum</th>
            <th>Komisyon Değerlendirmeleri</th> 
            <th style="width:100px; text-align:right;">İşlem</th>
        </tr>
    </thead>
    <tbody id="komisyonTabloGv">
        @foreach (var fikir in Model)
        {
            <tr data-durum="@fikir.Durum"
                data-baslik="@fikir.Baslik.ToLower()"
                data-yazar="@fikir.BasvuruSahibiAdSoyad.ToLower()"
                data-tarih="@fikir.OlusturmaTarihi.ToString("yyyy-MM-ddTHH:mm:ss")">
                <td class="td-muted">#@fikir.Id</td>
                <td class="td-primary">@fikir.Baslik</td>
                <td class="td-muted">@fikir.BasvuruSahibiAdSoyad</td>
                <td class="td-muted">@fikir.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    @switch (fikir.Durum)
                    {
                        case "KomisyonOnayiBekliyor":
                            <span class="badge badge-kom-bekliyor">Puanlama Devam Ediyor</span>
                            break;
                        case "KomisyonOnayli":
                            <span class="badge badge-kom-onaylı" style="background:#f0fdf4; color:#15803d; border:1px solid #dcfce7;">Kabul Edildi</span>
                            break;
                        case "KomisyonOnayiRetli":
                            <span class="badge badge-on-retli" style="background:#fef2f2; color:#b91c1c; border:1px solid #fee2e2;">Reddedildi</span>
                            break;
                        default:
                            <span class="badge badge-taslak">@fikir.Durum</span>
                            break;
                    }
                </td>


                <td>
                    @if (fikir.KomisyonPuanlari != null && fikir.KomisyonPuanlari.Any())
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:8px;">
                            @foreach (var p in fikir.KomisyonPuanlari)
                            {
                                <div style="background:#f5f3ff; border:1px solid #ddd6fe; border-radius:8px; padding:4px 10px; min-width:140px;">
                                    <div style="display:flex; justify-content:space-between; align-items:center;">
                                        <span style="font-size:11.5px; font-weight:600; color:#4c1d95;">@p.Isim</span>
                                        <span style="font-size:12px; font-weight:700; color:#7c3aed;">@p.Puan</span>
                                    </div>
                                    <div style="font-size:9px; color:#8b5cf6; text-transform:uppercase; font-weight:700;">
                                        <i class="bi bi-award-fill me-1"></i>@p.Rol
                                    </div>
                                </div>
                            }


                            @for (int i = 0; i < (3 - fikir.KomisyonPuanlari.Count); i++)
                            {
                                <div style="border:1px dashed #d1d5db; border-radius:8px; padding:4px 10px; min-width:140px; display:flex; align-items:center; justify-content:center; background:#f9fafb;">
                                    <span style="font-size:10px; color:#9ca3af; font-style:italic;">Puan Bekleniyor...</span>
                                </div>
                            }
                        </div>

                        @if (fikir.KomisyonPuanlari.Count == 3)
                        {
                            var ortalama = fikir.KomisyonPuanlari.Average(x => x.Puan);
                            <div style="display:flex; align-items:center; gap:8px; padding:6px 12px; background:rgba(79, 70, 229, 0.05); border-radius:10px; width:fit-content; border:1px solid rgba(79, 70, 229, 0.1);">
                                <span style="font-size:11px; font-weight:700; color:#4f46e5; text-transform:uppercase; letter-spacing:0.02em;">
                                    <i class="bi bi-calculator me-1"></i> Komisyon Ortalaması:
                                </span>
                                <span style="font-size:14px; font-weight:800; color:#4f46e5;">
                                    @ortalama.ToString("F2")
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="display:flex; gap:8px;">
                            @for (int i = 0; i < 3; i++)
                            {
                                <div style="border:1px dashed #d1d5db; border-radius:8px; padding:8px; min-width:140px; text-align:center; background:#f9fafb;">
                                    <i class="bi bi-person-dash" style="color:#d1d5db;"></i>
                                </div>
                            }
                        </div>
                    }
                </td>

                <td style="text-align:right;">
                    @if (fikir.KomisyonPuanlari.Any(p => p.Isim == User.Identity.Name || p.Isim == (User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value)))
                    {
                        <a asp-action="CommissionEvaluate" asp-route-id="@fikir.Id" class="btn-table" style="color:#b45309; border-color:#fde68a; background:#fffbeb;">
                            <i class="bi bi-arrow-repeat me-1"></i>Güncelle
                        </a>
                    }
                    else
                    {
                        <a asp-action="CommissionEvaluate" asp-route-id="@fikir.Id" class="btn-table" style="color:#1d4ed8; border-color:#dbeafe; background:#eff6ff;">
                            <i class="bi bi-star me-1"></i>Puan Ver
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div id="komisyonBosUyarisi" style="padding:48px 20px; text-align:center; display:none; background:#fff; border:1px solid #e5e7eb; border-radius:6px;">
    <div style="width:44px; height:44px; border-radius:10px; background:#f1f5f9; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
        <i class="bi bi-funnel" style="font-size:20px; color:#64748b;"></i>
    </div>
    <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
        Kriterlere uygun fikir bulunamadı
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        komisyonFiltreleVeSirala();
    });

    function komisyonFiltreleVeSirala() {
        const tbody = document.getElementById("komisyonTabloGv");
        if (!tbody) return;

        const aramaKelimesi = document.getElementById("komisyonAramaInput").value.trim().toLowerCase();
        const secilenDurum = document.getElementById("komisyonDurumFiltre").value;
        const satirlar = Array.from(tbody.querySelectorAll("tr"));
        let eslesenSatirSayisi = 0;

     
        satirlar.sort((a, b) => {
            const tarihA = new Date(a.getAttribute("data-tarih"));
            const tarihB = new Date(b.getAttribute("data-tarih"));
            return tarihB - tarihA;
        });

 
        satirlar.forEach(satir => {
            const satirDurum = satir.getAttribute("data-durum");
            const satirBaslik = satir.getAttribute("data-baslik");
            const satirYazar = satir.getAttribute("data-yazar");

            const durumUygundur = (secilenDurum === "TUMU" || satirDurum === secilenDurum);
            const kelimeUygundur = (aramaKelimesi === "" ||
                satirBaslik.includes(aramaKelimesi) ||
                satirYazar.includes(aramaKelimesi));

            if (durumUygundur && kelimeUygundur) {
                satir.style.display = "";
                eslesenSatirSayisi++;
            } else {
                satir.style.display = "none";
            }

            tbody.appendChild(satir);
        });

   
        const bosUyarisi = document.getElementById("komisyonBosUyarisi");
        if (bosUyarisi) {
            if (eslesenSatirSayisi === 0) {
                bosUyarisi.style.display = "block";
            } else {
                bosUyarisi.style.display = "none";
            }
        }
    }
</script>