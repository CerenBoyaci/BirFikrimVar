@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Komisyon Paneli";
    ViewData["PageTitle"] = "Komisyon Paneli";
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-award me-2" style="color:#9ca3af;"></i>Komisyon Onayı Bekleyen Fikirler
        </span>
        @if (Model != null && Model.Any())
        {
            <span style="font-size:11.5px; color:#9ca3af; font-weight:500;">@Model.Count kayıt</span>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th style="width:60px;">ID</th>
                    <th>Başlık</th>
                    <th>Başvuru Sahibi</th>
                    <th style="width:130px;">Tarih</th>
                    <th style="width:140px;">Durum</th>
                    <th style="width:100px; text-align:right;">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fikir in Model)
                {
                    <tr>
                        <td class="td-muted" style="font-variant-numeric:tabular-nums;">#@fikir.Id</td>
                        <td class="td-primary">@fikir.Baslik</td>
                        <td class="td-muted">@fikir.BasvuruSahibiAdSoyad</td>
                        <td class="td-muted">@fikir.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><span class="badge badge-kom-bekliyor">Komisyon Bekliyor</span></td>
                        <td style="text-align:right;">
                            <a asp-action="CommissionEvaluate"
                               asp-route-id="@fikir.Id"
                               class="btn-table"
                               style="color:#1d4ed8; border-color:#dbeafe; background:#eff6ff;">
                                <i class="bi bi-star me-1"></i>Puan Ver
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:48px 20px; text-align:center;">
            <div style="width:44px; height:44px; border-radius:10px; background:#f5f3ff; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
                <i class="bi bi-award" style="font-size:20px; color:#7c3aed;"></i>
            </div>
            <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
                Bekleyen fikir yok
            </div>
            <div style="font-size:12.5px; color:#9ca3af;">
                Şu anda komisyon değerlendirmesi bekleyen bir fikir bulunmamaktadır.
            </div>
        </div>
    }
</div>