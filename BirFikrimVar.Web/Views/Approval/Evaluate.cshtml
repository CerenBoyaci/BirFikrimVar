@model BirFikrimVar.Web.Models.OnOnayDegerlendirmeViewModel

@{
    ViewData["Title"] = "Ön Onay Değerlendirmesi";
    ViewData["PageTitle"] = "Ön Onay Değerlendirmesi";

    var guncelleMi = Model.KategoriPuanlari.Any(x => x.Puan > 0);
}

<div style="display:grid; grid-template-columns:1fr 320px; gap:16px; align-items:start;">

    @* Sol: Fikir detayı *@
    <div style="display:flex; flex-direction:column; gap:14px;">

        <div class="card">
            <div class="card-header">
                <span class="card-header-title">
                    <i class="bi bi-lightbulb me-2" style="color:#9ca3af;"></i>@Model.Fikir.Baslik
                </span>
            </div>
            <div class="card-body" style="display:flex; flex-direction:column; gap:16px;">

                <div>
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Özet</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.Ozet</p>
                </div>

                <div style="border-top:1px solid #f0f0f0; padding-top:14px;">
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Kapsam</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.Kapsam</p>
                </div>

                <div style="border-top:1px solid #f0f0f0; padding-top:14px;">
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Yenilikçi Yanı</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.YenilikciYan</p>
                </div>

            </div>
        </div>

        @* SWOT *@
        <div class="card">
            <div class="card-header">
                <span class="card-header-title">
                    <i class="bi bi-grid-2x2 me-2" style="color:#9ca3af;"></i>SWOT Analizi
                </span>
            </div>
            <div class="card-body">
                <div class="swot-grid">
                    <div class="swot-card swot-guclu">
                        <div class="swot-label">Güçlü Yönler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.GucluYonler</p>
                    </div>
                    <div class="swot-card swot-zayif">
                        <div class="swot-label">Zayıf Yönler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.ZayifYonler</p>
                    </div>
                    <div class="swot-card swot-firsatlar">
                        <div class="swot-label">Fırsatlar</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.Firsatlar</p>
                    </div>
                    <div class="swot-card swot-tehditler">
                        <div class="swot-label">Tehditler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.Tehditler</p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    @* Sağ: Puanlama formu *@
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i class="bi bi-star me-2" style="color:#9ca3af;"></i>Puanlama
                <span class="hint" style="margin-left:4px;">1 — 10</span>
            </span>
            @if (guncelleMi)
            {
                <span style="font-size:10.5px; font-weight:600; background:#fff7ed; color:#b45309; border:1px solid #fde68a; padding:2px 8px; border-radius:4px;">
                    Güncelleme modu
                </span>
            }
        </div>
        <div class="card-body">
            <form asp-controller="Approval"
                  asp-action="@(guncelleMi ? "EvaluateUpdate" : "Evaluate")"
                  method="post">
                <input type="hidden" asp-for="FikirId" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 mb-3"
                     style="font-size:12.5px; border-radius:6px;"></div>

                @* Puan satırları *@
                <div style="margin-bottom:16px;">
                    @for (int i = 0; i < Model.KategoriPuanlari.Count; i++)
                    {
                        <input type="hidden" asp-for="KategoriPuanlari[i].KategoriId" />
                        <input type="hidden" asp-for="KategoriPuanlari[i].KategoriAdi" />

                        <div class="puan-row">
                            <span class="puan-row-label">@Model.KategoriPuanlari[i].KategoriAdi</span>
                            <input asp-for="KategoriPuanlari[i].Puan"
                                   type="number"
                                   min="1"
                                   max="10"
                                   class="form-control puan-input"
                                   placeholder="—"
                                   required
                                   style="width:64px; text-align:center; font-weight:700;" />
                        </div>
                        <span asp-validation-for="KategoriPuanlari[i].Puan"
                              style="font-size:11px; color:#dc2626; display:block; text-align:right; margin-top:-6px; margin-bottom:4px;"></span>
                    }
                </div>

                @* Ortalama göstergesi *@
                <div class="puan-ortalama-box mb-4">
                    <span style="font-size:12px; opacity:.8;">Ortalama Puan</span>
                    <span class="puan-ortalama-val">—</span>
                </div>

                <div style="background:#f9fafb; border:1px solid #f0f0f0; border-radius:6px; padding:11px 13px; margin-bottom:16px; display:flex; gap:8px; align-items:flex-start;">
                    <i class="bi bi-info-circle" style="color:#9ca3af; font-size:13px; margin-top:1px; flex-shrink:0;"></i>
                    <div style="font-size:11.5px; color:#6b7280; line-height:1.5;">
                        Ortalama <span style="font-weight:600; color:#374151;">6'nın üzerindeyse</span> fikir komisyon aşamasına aktarılır,
                        <span style="font-weight:600; color:#374151;">6 veya altındaysa</span> reddedilir.
                    </div>
                </div>

                <div style="display:flex; flex-direction:column; gap:8px;">
                    <button type="submit" class="btn btn-primary w-100" style="padding:9px;">
                        @if (guncelleMi)
                        {
                            <i class="bi bi-arrow-repeat me-1"></i><span>Değerlendirmeyi Güncelle</span>
                        }
                        else
                        {
                            <i class="bi bi-check me-1"></i><span>Değerlendirmeyi Tamamla</span>
                        }
                    </button>
                    <a asp-action="PreApprovalList"
                       class="btn btn-outline-secondary w-100"
                       style="padding:8px; text-align:center;">
                        Listeye Dön
                    </a>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}