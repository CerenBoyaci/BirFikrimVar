@model BirFikrimVar.Web.Models.KomisyonDegerlendirmeViewModel

@{
    ViewData["Title"] = "Komisyon Değerlendirmesi";
}

<div class="row">
 
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Fikir Detayı: @Model.Fikir.Baslik</h5>
            </div>
            <div class="card-body">
                <h6 class="text-primary fw-bold">Özet</h6>
                <p>@Model.Fikir.Ozet</p>
                <hr />
                <h6 class="text-primary fw-bold">Kapsam</h6>
                <p>@Model.Fikir.Kapsam</p>
                <hr />
                <h6 class="text-primary fw-bold">Yenilikçi Yanı</h6>
                <p>@Model.Fikir.YenilikciYan</p>

                <h5 class="mt-4 border-bottom pb-2">SWOT Analizi</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-success border-4">
                            <strong class="text-success">Güçlü Yönler</strong>
                            <p class="mb-0 small">@Model.Fikir.GucluYonler</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-danger border-4">
                            <strong class="text-danger">Zayıf Yönler</strong>
                            <p class="mb-0 small">@Model.Fikir.ZayifYonler</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-info border-4">
                            <strong class="text-info">Fırsatlar</strong>
                            <p class="mb-0 small">@Model.Fikir.Firsatlar</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border-start border-warning border-4">
                            <strong class="text-warning">Tehditler</strong>
                            <p class="mb-0 small">@Model.Fikir.Tehditler</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

  
    <div class="col-md-4">
        <div class="card shadow-sm border-0 border-top border-info border-4 sticky-top" style="top: 20px;">
            <div class="card-header bg-white">
                <h5 class="mb-0 text-info"><i class="bi bi-award-fill me-2"></i>Komisyon Kararı</h5>
            </div>
            <div class="card-body">
                <form asp-action="CommissionEvaluate" method="post">
                    <input type="hidden" asp-for="FikirId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Puan" class="form-label fw-bold">Nihai Puanınız (1-10)</label>
                        <input asp-for="Puan" type="number" min="1" max="10" class="form-control form-control-lg text-center fw-bold" placeholder="Örn: 8" required />
                        <span asp-validation-for="Puan" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-light border small mt-2">
                        <i class="bi bi-info-circle-fill text-info me-1"></i> Sistemdeki 3 komisyon üyesi değerlendirmesini tamamladığında ortalama hesaplanır.
                        <strong>Ortalama 8 ve üzeri</strong> ise fikir kabul edilir.
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-info text-white fw-bold">
                            <i class="bi bi-check-circle-fill"></i> Puanı Kaydet / Güncelle
                        </button>
                        <a asp-action="CommissionList" class="btn btn-outline-secondary">Listeye Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
