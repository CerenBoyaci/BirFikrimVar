@model BirFikrimVar.Web.Models.KomisyonDegerlendirmeViewModel

@{
    ViewData["Title"] = "Komisyon Değerlendirmesi";
    ViewData["PageTitle"] = "Komisyon Değerlendirmesi";
}

<div style="display:grid; grid-template-columns:1fr 320px; gap:16px; align-items:start;">

    @* Sol: Fikir detayı *@
    <div style="display:flex; flex-direction:column; gap:14px;">

        <div class="card">
            <div class="card-header">
                <span class="card-header-title">
                    <i class="bi bi-lightbulb me-2" style="color:#9ca3af;"></i>@Model.Fikir.Baslik
                </span>
            </div>
            <div class="card-body" style="display:flex; flex-direction:column; gap:16px;">

                <div>
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Özet</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.Ozet</p>
                </div>

                <div style="border-top:1px solid #f0f0f0; padding-top:14px;">
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Kapsam</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.Kapsam</p>
                </div>

                <div style="border-top:1px solid #f0f0f0; padding-top:14px;">
                    <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:5px;">Yenilikçi Yanı</div>
                    <p style="font-size:13px; color:#374151; line-height:1.6; margin:0;">@Model.Fikir.YenilikciYan</p>
                </div>

            </div>
        </div>

        @* SWOT *@
        <div class="card">
            <div class="card-header">
                <span class="card-header-title">
                    <i class="bi bi-grid-2x2 me-2" style="color:#9ca3af;"></i>SWOT Analizi
                </span>
            </div>
            <div class="card-body">
                <div class="swot-grid">
                    <div class="swot-card swot-guclu">
                        <div class="swot-label">Güçlü Yönler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.GucluYonler</p>
                    </div>
                    <div class="swot-card swot-zayif">
                        <div class="swot-label">Zayıf Yönler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.ZayifYonler</p>
                    </div>
                    <div class="swot-card swot-firsatlar">
                        <div class="swot-label">Fırsatlar</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.Firsatlar</p>
                    </div>
                    <div class="swot-card swot-tehditler">
                        <div class="swot-label">Tehditler</div>
                        <p style="font-size:12.5px; color:#374151; line-height:1.55; margin:0;">@Model.Fikir.Tehditler</p>
                    </div>
                </div>
            </div>
        </div>

        @* Dosyalar Bölümü *@
        <div style="border-top:1px solid #f0f0f0; padding-top:14px;">
            <div style="font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:8px;">
                <i class="bi bi-paperclip me-1"></i> Ek Dosyalar
            </div>

            @if (Model.Fikir.Dosyalar != null && Model.Fikir.Dosyalar.Any())
            {
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    @foreach (var dosya in Model.Fikir.Dosyalar)
                    {
                        <a asp-controller="Ideas"
                           asp-action="DosyaIndir"
                           asp-route-fikirId="@Model.FikirId"
                           asp-route-dosyaId="@dosya.Id"
                           class="btn btn-sm btn-light"
                           style="border: 1px solid #e5e7eb; font-size: 12px; display: flex; align-items: center; gap: 6px; padding: 5px 10px; background: #fff;">
                            <i class="bi bi-file-earmark-arrow-down" style="color: #3b82f6;"></i>
                            <span>@dosya.DosyaAdi</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="font-size: 12px; color: #9ca3af; font-style: italic;">
                    Bu fikir için yüklenmiş bir dosya bulunmamaktadır.
                </div>
            }
        </div>

    </div>

    @* Sağ: Değerlendirme formu *@
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i class="bi bi-award me-2" style="color:#9ca3af;"></i>Komisyon Kararı
            </span>
        </div>
        <div class="card-body">
            <form asp-action="CommissionEvaluate" method="post">
                <input type="hidden" asp-for="FikirId" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 mb-3"
                     style="font-size:12.5px; border-radius:6px;"></div>

                <div class="mb-3">
                    <label asp-for="Puan" class="form-label">
                        Nihai Puanınız
                        <span class="hint">— 1 ile 10 arası</span>
                    </label>
                    <input asp-for="Puan"
                           type="number"
                           min="1"
                           max="10"
                           class="form-control puan-input"
                           placeholder="8"
                           required
                           style="font-size:20px; font-weight:700; text-align:center; padding:12px;" />
                    <span asp-validation-for="Puan"
                          style="font-size:11.5px; color:#dc2626; margin-top:3px; display:block;"></span>
                </div>

                <div style="background:#f9fafb; border:1px solid #f0f0f0; border-radius:6px; padding:11px 13px; margin-bottom:16px; display:flex; gap:8px; align-items:flex-start;">
                    <i class="bi bi-info-circle" style="color:#9ca3af; font-size:13px; margin-top:1px; flex-shrink:0;"></i>
                    <div style="font-size:11.5px; color:#6b7280; line-height:1.5;">
                        Tüm komisyon üyeleri değerlendirmesini tamamladığında ortalama hesaplanır.
                        <span style="font-weight:600; color:#374151;">Ortalama 8 ve üzeri</span> ise fikir kabul edilir.
                    </div>
                </div>

                <div style="display:flex; flex-direction:column; gap:8px;">
                    <button type="submit" class="btn btn-primary w-100" style="padding:9px;">
                        @if (Model.Puan > 0)
                        {
                            <i class="bi bi-arrow-repeat me-1"></i><span>Puanı Güncelle</span>
                        }
                        else
                        {
                            <i class="bi bi-check me-1"></i><span>Puanı Kaydet</span>
                        }
                    </button>
                    <a asp-action="CommissionList" class="btn btn-outline-secondary w-100" style="padding:8px; text-align:center;">
                        Listeye Dön
                    </a>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}