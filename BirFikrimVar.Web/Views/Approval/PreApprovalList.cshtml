@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Ön Onay Paneli";
    ViewData["PageTitle"] = "Ön Onay Paneli";
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-ui-checks me-2" style="color:#9ca3af;"></i>Ön Onay Paneli
        </span>
        <div style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
            <div class="d-flex align-items-center gap-3">
                <div style="position: relative; flex: 1; max-width: 300px;">
                    <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #9ca3af;">
                        <i class="bi bi-search" style="font-size: 14px;"></i>
                    </span>
                    <input type="text"
                           id="panelAramaInput"
                           class="form-control"
                           placeholder="Başlık veya başvuru sahibi ara..."
                           style="font-size: 13px; border-color: #d1d5db; border-radius: 6px; padding: 6px 12px 6px 32px; width: 100%;"
                           onkeyup="panelFiltreleVeSirala()" />
                </div>

                <div style="position: relative; width: 200px;">
                    <select id="panelDurumFiltre"
                            class="form-select"
                            style="font-size: 13px; border-color: #d1d5db; border-radius: 6px; padding: 6px 12px; width: 100%;"
                            onchange="panelFiltreleVeSirala()">
                        <option value="TUMU">Tüm Durumlar</option>
                        <option value="OnOnayBekliyor">Ön Onay Bekliyor</option>
                        <option value="KomisyonOnayiBekliyor">Komisyonda</option>
                        <option value="OnOnayRetli">Ön Onay Retli</option>
                        <option value="KomisyonOnayli">Kabul Edildi</option>
                    </select>
                </div>
            </div>
        </div>
        @if (Model != null && Model.Any())
        {
            <span style="font-size:11.5px; color:#9ca3af; font-weight:500;">@Model.Count kayıt</span>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th style="width:60px;">ID</th>
                    <th>Başlık</th>
                    <th>Başvuru Sahibi</th>
                    <th style="width:130px;">Tarih</th>
                    <th style="width:150px;">Durum</th>
                    <th style="width:110px; text-align:right;">İşlem</th>
                    <th>Ön Onay Puanları</th>
                </tr>
            </thead>
            <tbody id="panelTabloGv">
                @foreach (var fikir in Model)
                {
                    <tr data-durum="@fikir.Durum"
                        data-baslik="@fikir.Baslik.ToLower()"
                        data-yazar="@fikir.BasvuruSahibiAdSoyad.ToLower()"
                        data-tarih="@fikir.OlusturmaTarihi.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="td-muted" style="font-variant-numeric:tabular-nums;">#@fikir.Id</td>
                        <td class="td-primary">@fikir.Baslik</td>
                        <td class="td-muted">@fikir.BasvuruSahibiAdSoyad</td>
                        <td class="td-muted">@fikir.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @switch (fikir.Durum)
                            {
                                case "OnOnayBekliyor":
                                    <span class="badge badge-on-bekliyor">Ön Onay Bekliyor</span>
                                    break;
                                case "KomisyonOnayiBekliyor":
                                    <span class="badge badge-kom-bekliyor">Komisyonda</span>
                                    break;
                                case "OnOnayRetli":
                                    <span class="badge badge-on-retli">Ön Onay Retli</span>
                                    break;
                                case "KomisyonOnayli":
                                    <span class="badge badge-kom-onaylı">Kabul Edildi</span>
                                    break;
                                default:
                                    <span class="badge badge-taslak">@fikir.Durum</span>
                                    break;
                            }
                        </td>
                        <td style="text-align:right;">
                            @{
                              
                                var komisyonPuanlamayaBasladimi = fikir.KomisyonPuanlari != null && fikir.KomisyonPuanlari.Any();
                            }

                            @if (fikir.Durum == "OnOnayBekliyor")
                            {
                             
                                <a asp-action="Evaluate"
                                   asp-route-id="@fikir.Id"
                                   class="btn-table"
                                   style="color:#1d4ed8; border-color:#dbeafe; background:#eff6ff;">
                                    <i class="bi bi-pencil me-1"></i>Değerlendir
                                </a>
                            }
                            else if ((fikir.Durum == "KomisyonOnayiBekliyor" || fikir.Durum == "OnOnayRetli") && !komisyonPuanlamayaBasladimi)
                            {
                              
                                <a asp-action="Evaluate"
                                   asp-route-id="@fikir.Id"
                                   class="btn-table"
                                   style="color:#b45309; border-color:#fde68a; background:#fffbeb;">
                                    <i class="bi bi-arrow-repeat me-1"></i>@(fikir.Durum == "OnOnayRetli" ? "Kararı Değiştir" : "Güncelle")
                                </a>
                            }
                            else
                            {
                            
                                <span class="badge" style="background:#f1f5f9; color:#64748b; border:1px solid #e2e8f0; font-size:11px; font-weight:500; padding: 6px 10px;">
                                    <i class="bi bi-lock-fill me-1"></i>@(komisyonPuanlamayaBasladimi ? "Komisyonda / Kilitli" : "Tamamlandı")
                                </span>
                            }
                        </td>
                        <td>
                            @if (fikir.OnOnayPuanlari != null && fikir.OnOnayPuanlari.Any())
                            {
                                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                                    @foreach (var p in fikir.OnOnayPuanlari)
                                    {
                                        <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:6px 10px; min-width:130px; display:flex; flex-direction:column; gap:2px;">
                                            <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
                                                <span style="font-size:12px; font-weight:600; color:#1e293b;">@p.Isim</span>
                                                <span style="font-size:12px; font-weight:700; color:#2563eb;">@p.Puan</span>
                                            </div>
                                            <div style="display:flex; align-items:center;">
                                                @if (p.Rol == "Admin")
                                                {
                                                    <span style="font-size:9px; background:#fee2e2; color:#991b1b; padding:1px 5px; border-radius:4px; font-weight:700; text-transform:uppercase;">
                                                        <i class="bi bi-shield-lock me-1"></i>@p.Rol
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="font-size:9px; background:#e0f2fe; color:#0369a1; padding:1px 5px; border-radius:4px; font-weight:700; text-transform:uppercase;">
                                                        <i class="bi bi-person-badge me-1"></i>@p.Rol
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="display:flex; gap:6px;">
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <span style="width:24px; height:24px; border:1px dashed #d1d5db; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; color:#d1d5db; font-size:10px;" title="Puan Bekleniyor">
                                            <i class="bi bi-plus"></i>
                                        </span>
                                    }

                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div id="panelBosUyarisi" style="padding:48px 20px; text-align:center; display:none;">
            <div style="width:44px; height:44px; border-radius:10px; background:#f1f5f9; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
                <i class="bi bi-funnel" style="font-size:20px; color:#64748b;"></i>
            </div>
            <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
                Kriterlere uygun kayıt bulunamadı
            </div>
        </div>
    }
    else
    {
        <div style="padding:48px 20px; text-align:center;">
            <div style="width:44px; height:44px; border-radius:10px; background:#eff6ff; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
                <i class="bi bi-ui-checks" style="font-size:20px; color:#3b82f6;"></i>
            </div>
            <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
                Bekleyen fikir yok
            </div>
            <div style="font-size:12.5px; color:#9ca3af;">
                Şu anda ön onay bekleyen bir fikir bulunmamaktadır.
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
 
        panelFiltreleVeSirala();
    });

    function panelFiltreleVeSirala() {
        const tbody = document.getElementById("panelTabloGv");
        if (!tbody) return;

        const aramaKelimesi = document.getElementById("panelAramaInput").value.trim().toLowerCase();
        const secilenDurum = document.getElementById("panelDurumFiltre").value;
        const satirlar = Array.from(tbody.querySelectorAll("tr"));
        let eslesenSatirSayisi = 0;

   
        satirlar.sort((a, b) => {
            const tarihA = new Date(a.getAttribute("data-tarih"));
            const tarihB = new Date(b.getAttribute("data-tarih"));
            return tarihB - tarihA;
        });

    
        satirlar.forEach(satir => {
            const satirDurum = satir.getAttribute("data-durum");
            const satirBaslik = satir.getAttribute("data-baslik");
            const satirYazar = satir.getAttribute("data-yazar");

  
            const durumUygundur = (secilenDurum === "TUMU" || satirDurum === secilenDurum);

            const kelimeUygundur = (aramaKelimesi === "" ||
                satirBaslik.includes(aramaKelimesi) ||
                satirYazar.includes(aramaKelimesi));

   
            if (durumUygundur && kelimeUygundur) {
                satir.style.display = "";
                eslesenSatirSayisi++;
            } else {
                satir.style.display = "none";
            }

 
            tbody.appendChild(satir);
        });


        const bosUyarisi = document.getElementById("panelBosUyarisi");
        if (eslesenSatirSayisi === 0) {
            bosUyarisi.style.display = "block";
        } else {
            bosUyarisi.style.display = "none";
        }
    }
</script>