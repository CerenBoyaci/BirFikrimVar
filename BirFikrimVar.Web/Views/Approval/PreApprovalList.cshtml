@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Ön Onay Paneli";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="bi bi-card-checklist me-2"></i>Ön Onay Paneli</h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Başlık</th>
                        <th>Başvuru Sahibi</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fikir in Model)
                    {
                        <tr>
                            <td>#@fikir.Id</td>
                            <td class="fw-bold">@fikir.Baslik</td>
                            <td>@fikir.BasvuruSahibiAdSoyad</td>
                            <td>@fikir.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (fikir.Durum == "OnOnayBekliyor")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Bekliyor</span>
                                }
                                else if (fikir.Durum == "KomisyonOnayiBekliyor")
                                {
                                    <span class="badge bg-info text-dark"><i class="bi bi-arrow-right-circle me-1"></i>Komisyonda</span>
                                }
                                else if (fikir.Durum == "OnOnayRetli")
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Ön Onay Red</span>
                                }
                                else if (fikir.Durum == "KomisyonOnayli")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-all me-1"></i>Kabul Edildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@fikir.Durum</span>
                                }
                            </td>
                            <td class="text-end">
                                @* Güncelleme butonu sadece komisyon aşaması kesinleşmediyse (Kabul/Ret) aktif olsun *@
                                @if (fikir.Durum == "OnOnayBekliyor")
                                {
                                    <a asp-action="Evaluate" asp-route-id="@fikir.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil-square"></i> Değerlendir
                                    </a>
                                }
                                else if (fikir.Durum == "KomisyonOnayiBekliyor" || fikir.Durum == "OnOnayRetli")
                                {
                                    <a asp-action="Evaluate" asp-route-id="@fikir.Id" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-arrow-repeat"></i> Güncelle
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info text-center">
                İşlem yapılacak bir fikir bulunmamaktadır.
            </div>
        }
    </div>
</div>