@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["PageTitle"] = "Ana Sayfa";
    Layout = "_Layout";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
     
        <div>
           
            <div style="font-size:12px; color:#9ca3af; margin-top:1px;">
                Fikir Yönetim Sistemi süreç bilgilendirme ekranı
            </div>
        </div>
    </div>

    <div class="stat-grid">

        <div class="stat-card">
            <div class="stat-card-top">
               
                <span class="stat-trend up">1. Aşama</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">Fikir Başvurusu</div>
                <div class="stat-label">
                    Kullanıcı tarafından sisteme yeni fikir kaydı oluşturulur
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
               
                <span class="stat-trend warn">2. Aşama</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">Ön Değerlendirme</div>
                <div class="stat-label">
                    İlgili birim tarafından ön inceleme süreci yürütülür
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
               
                <span class="stat-trend warn">3. Aşama</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">Komisyon İncelemesi</div>
                <div class="stat-label">
                    Komisyon tarafından detaylı değerlendirme gerçekleştirilir
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
             
                <span class="stat-trend up">4. Aşama</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">Proje Süreci</div>
                <div class="stat-label">
                    Onaylanan fikirler proje sürecine dahil edilir
                </div>
            </div>
        </div>

    </div>

    <div class="card mt-3">

        <div class="card-header">
            <span class="card-header-title">
                Fikir Yönetim Sistemi İşleyiş Süreci
            </span>

            <a asp-controller="Ideas" asp-action="Index" class="btn-table">
                Tüm Başvurular →
            </a>
        </div>

        <table class="table">

            <thead>
                <tr>
                    <th>Süreç Adımı</th>
                    <th>Açıklama</th>
                    <th>Sorumlu Birim</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td class="td-primary">Fikir Başvurusu</td>

                    <td class="td-muted">
                        Kullanıcı tarafından sistem üzerinden fikir başvurusu gerçekleştirilir
                    </td>

                    <td class="td-muted">
                        Personel
                    </td>

                    <td>
                        <span class="badge badge-taslak">
                            Başvuru Kaydı Oluşturuldu
                        </span>
                    </td>

                    
                </tr>

                <tr>
                    <td class="td-primary">Ön Değerlendirme Süreci</td>

                    <td class="td-muted">
                        Başvuru, ilgili birim tarafından uygunluk kriterlerine göre incelenir
                    </td>

                    <td class="td-muted">
                        Ön Değerlendirme Ekibi
                    </td>

                    <td>
                        <span class="badge badge-on-bekliyor">
                            Değerlendirme Devam Ediyor
                        </span>
                    </td>

                    
                </tr>

                <tr>
                    <td class="td-primary">Komisyon Değerlendirmesi</td>

                    <td class="td-muted">
                        Komisyon tarafından teknik ve operasyonel inceleme yapılır
                    </td>

                    <td class="td-muted">
                        Değerlendirme Komisyonu
                    </td>

                    <td>
                        <span class="badge badge-kom-onaylı">
                            Komisyon İncelemesi Tamamlandı
                        </span>
                    </td>

                  
                </tr>

                <tr>
                    <td class="td-primary">Projelendirme Süreci</td>

                    <td class="td-muted">
                        Uygun bulunan fikirler proje planına dahil edilerek uygulamaya alınır
                    </td>

                    <td class="td-muted">
                        Yönetim ve Proje Ekibi
                    </td>

                    <td>
                        <span class="badge badge-kom-onaylı">
                            Uygulama Süreci Başlatıldı
                        </span>
                    </td>

                    
                </tr>

            </tbody>

        </table>

    </div>
}
else
{
    <div class="lp-root">

        @* Arkaplan grid *@
        <div class="lp-grid-bg"></div>
        <div class="lp-glow-1"></div>
        <div class="lp-glow-2"></div>

        @* NAV *@
        <nav class="lp-nav">
            <div class="lp-nav-brand">
                <img src="~/imgs/BirFikrimVar.png" alt="Logo" class="lp-nav-logo" />
                <span class="lp-nav-name">Bir Fikrim Var</span>
            </div>
            <div class="lp-nav-actions">
                <a asp-controller="Account" asp-action="Giris" class="lp-nav-link">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Kayit" class="lp-nav-cta">Kayıt Ol</a>
            </div>
        </nav>

        @* HERO *@
        <section class="lp-hero">

            @* Sol: metin *@
            <div class="lp-hero-left">
                <div class="lp-badge">
                    <span class="lp-badge-dot"></span>
                    Kurumsal İnovasyon Platformu
                </div>

                <h1 class="lp-h1">
                    Fikirleri<br />
                    <span class="lp-h1-accent">Gerçeğe</span><br />
                    Dönüştürün
                </h1>

                <p class="lp-desc">
                    Çalışanlarınızın fikirlerini sistematik olarak toplayın,
                    değerlendirin ve onay süreçleriyle projeye dönüştürün.
                </p>

                <div class="lp-cta-row">
                    <a asp-controller="Account" asp-action="Giris" class="lp-btn-primary">
                        Platforma Giriş Yap
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                    <a asp-controller="Account" asp-action="Kayit" class="lp-btn-ghost">
                        Hesap Oluştur
                    </a>
                </div>

                <div class="lp-feature-row">
                   
           

                    <div class="lp-feature-row">
                        <div class="lp-feature-item">
                            <div class="lp-feature-head">
                            
                                <span class="lp-feature-title">Hızlı İnovasyon</span>
                            </div>
                        </div>

                        <div class="lp-feature-div"></div>

                        <div class="lp-feature-item">
                            <div class="lp-feature-head">
                           
                                <span class="lp-feature-title">Geleceği Tasarla</span>
                            </div>
                        </div>

                        <div class="lp-feature-div"></div>

                        <div class="lp-feature-item">
                            <div class="lp-feature-head">
                   
                                <span class="lp-feature-title">Değer Yarat</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Sağ: dashboard preview *@
            @* Sağ: dashboard preview yerine Süreç Akışı *@
            <div class="lp-hero-right">
                <div class="lp-dashboard">

                    @* Mini topbar *@
                    <div class="lp-db-topbar">
                        <div class="lp-db-dots">
                            <span class="lp-dot lp-dot-red"></span>
                            <span class="lp-dot lp-dot-yellow"></span>
                            <span class="lp-dot lp-dot-green"></span>
                        </div>
                        <span class="lp-db-title">Sistem Nasıl İşler?</span>
                    </div>

                    <div class="lp-ad-container">
                        <div class="lp-ad-step">
                            <div class="lp-ad-icon">1</div>
                            <div class="lp-ad-content">
                                <div class="lp-ad-title">Fikrini Paylaş</div>
                                <p class="lp-ad-text">Hayalindeki projeyi sisteme gir, ilk adımı at.</p>
                            </div>
                        </div>

                        <div class="lp-ad-connector"></div>

                        <div class="lp-ad-step">
                            <div class="lp-ad-icon">2</div>
                            <div class="lp-ad-content">
                                <div class="lp-ad-title">Ön Onay Süreci</div>
                                <p class="lp-ad-text">Yöneticiler tarafından hızlıca değerlendirilir.</p>
                            </div>
                        </div>

                        <div class="lp-ad-connector"></div>

                        <div class="lp-ad-step">
                            <div class="lp-ad-icon">3</div>
                            <div class="lp-ad-content">
                                <div class="lp-ad-title">Komisyon Değerlendirmesi</div>
                                <p class="lp-ad-text">Uzman heyet fikrini detaylıca puanlar.</p>
                            </div>
                        </div>

                        <div class="lp-ad-connector"></div>

                        <div class="lp-ad-step highlight">
                            <div class="lp-ad-icon pulse">4</div>
                            <div class="lp-ad-content">
                                <div class="lp-ad-title">Fikir Hayat Bulur!</div>
                                <p class="lp-ad-text">Onaylanan fikrin gerçeğe dönüşsün.</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </section>

       

    </div>

    <style>
        body {
            overflow-x: hidden !important;
        }

        /* ── ROOT ── */
        .lp-root {
            min-height: 100vh;
            width: 100vw;
            background: #070b18;
            position: relative;
            overflow-x: hidden;
            font-family: -apple-system, 'Segoe UI', system-ui, sans-serif;
        }

    
        .lp-grid-bg {
            position: fixed;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.028) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.028) 1px, transparent 1px);
            background-size: 48px 48px;
            z-index: 0;
            pointer-events: none;
        }

        .lp-glow-1 {
            position: fixed;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
            top: -150px;
            right: -100px;
            pointer-events: none;
            z-index: 0;
        }

        .lp-glow-2 {
            position: fixed;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(249,115,22,0.07) 0%, transparent 70%);
            bottom: -100px;
            left: -100px;
            pointer-events: none;
            z-index: 0;
        }

  
        /* Navigasyon Çubuğu Genel Yapısı */
        /* Navigasyon Çubuğu Genel Yapısı */
        .lp-nav {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            /* Yatay padding'i 20px'den 10px'e düşürerek logoyu iyice sola yasladık */
            padding: 10px 10px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            height: 80px;
        }

        /* Sol Taraftaki Logo ve Yazı Grubu */
        .lp-nav-brand {
            display: flex;
            align-items: center;
            /* Gap değerini 12px'den 4px'e düşürerek yazıyı logoya yaklaştırdık */
            gap: 4px;
            margin-left: -10;
        }

        /* Navigasyon Logosu */
        .lp-nav-logo {
            /* Logonun fiziksel alanını daraltmak için width değerini 130px civarına çekebilirsiniz */
            width: 130px !important;
            height: 130px !important;
            object-fit: contain;
            filter: drop-shadow(0 0 15px rgba(56,189,248,0.5));
        }

        /* Marka İsmi (Bir Fikrim Var) */
        .lp-nav-name {
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
            white-space: nowrap;
            margin: 0;
            /* Görsel bir tık daha yakınlık isterseniz negatif margin verebilirsiniz */
            margin-left: -40px;
        }

        /* Sağ taraftaki butonlar (Giriş/Kayıt) */
        .lp-nav-actions {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-right: 10px;
        }

        .lp-nav-link {
            font-size: 13.5px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.15s;
        }

            .lp-nav-link:hover {
                color: #fff;
            }

        .lp-nav-cta {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            padding: 7px 18px;
            border-radius: 6px;
            text-decoration: none;
            transition: background 0.15s;
        }

            .lp-nav-cta:hover {
                background: rgba(255,255,255,0.13);
                color: #fff;
            }

        /* ── HERO ── */
        .lp-hero {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
            padding: 50px 40px 40px;
            max-width: 100%;
            margin: 0 auto;
            box-sizing: border-box;
        }

        /* Sol */
        .lp-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11.5px;
            font-weight: 600;
            color: rgba(56,189,248,0.85);
            background: rgba(56,189,248,0.08);
            border: 1px solid rgba(56,189,248,0.18);
            padding: 5px 12px;
            border-radius: 20px;
            margin-bottom: 22px;
            letter-spacing: 0.02em;
        }

        .lp-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #38bdf8;
            animation: blink 2s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }

        .lp-h1 {
            font-size: 48px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.04em;
            line-height: 1.08;
            margin: 0 0 18px;
        }

        .lp-h1-accent {
            background: linear-gradient(135deg, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .lp-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.42);
            line-height: 1.7;
            margin: 0 0 26px;
            max-width: 100%;
        }

        .lp-cta-row {
            display: flex;
            gap: 10px;
            margin-bottom: 36px;
            flex-wrap: wrap;
        }

        .lp-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 26px;
            background: #f97316;
            color: #fff;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.15s, transform 0.15s;
            letter-spacing: -0.01em;
        }

            .lp-btn-primary:hover {
                background: #ea6c0a;
                color: #fff;
                transform: translateY(-1px);
            }

        .lp-btn-ghost {
            display: inline-flex;
            align-items: center;
            padding: 12px 26px;
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.15s;
        }

            .lp-btn-ghost:hover {
                background: rgba(255,255,255,0.09);
                color: #fff;
            }

        .lp-trust {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .lp-trust-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .lp-trust-val {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .lp-trust-label {
            font-size: 11px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-trust-div {
            width: 1px;
            height: 28px;
            background: rgba(255,255,255,0.1);
        }

        /* Sağ: dashboard preview */
        .lp-dashboard {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            overflow: hidden;
            backdrop-filter: blur(12px);
            box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 24px 64px rgba(0,0,0,0.4);
        }

        .lp-db-topbar {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            background: rgba(255,255,255,0.02);
        }

        .lp-db-dots {
            display: flex;
            gap: 5px;
        }

        .lp-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
        }

        .lp-dot-red {
            background: #ef4444;
        }

        .lp-dot-yellow {
            background: #f59e0b;
        }

        .lp-dot-green {
            background: #22c55e;
        }

        .lp-db-title {
            font-size: 11px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-db-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .lp-db-stat {
            padding: 14px 12px;
            border-right: 1px solid rgba(255,255,255,0.06);
            text-align: center;
        }

            .lp-db-stat:last-child {
                border-right: none;
            }

        .lp-db-stat-val {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1;
            margin-bottom: 4px;
        }

        .lp-db-stat-label {
            font-size: 9.5px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-db-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: rgba(255,255,255,0.25);
            padding: 12px 14px 6px;
        }

        .lp-idea-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 9px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.12s;
        }

            .lp-idea-card:hover {
                background: rgba(255,255,255,0.03);
            }

        .lp-idea-title {
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.8);
            margin-bottom: 2px;
        }

        .lp-idea-meta {
            font-size: 10.5px;
            color: rgba(255,255,255,0.28);
        }

        .lp-idea-badge {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 5px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .lp-db-progress-wrap {
            padding: 12px 14px 14px;
        }

        .lp-db-progress-track {
            height: 4px;
            background: rgba(255,255,255,0.07);
            border-radius: 4px;
            overflow: hidden;
        }

        .lp-db-progress-fill {
            height: 100%;
            width: 68%;
            background: linear-gradient(90deg, #38bdf8, #818cf8);
            border-radius: 4px;
        }

        /* ── WORKFLOW ── */
        .lp-workflow {
            position: relative;
            z-index: 1;
            padding: 40px 40px 60px;
            max-width: 100%;
            margin: 0 auto;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .lp-wf-title {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.25);
            margin-bottom: 28px;
            text-align: center;
        }

        .lp-wf-steps {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .lp-wf-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            width: 160px;
        }

        .lp-wf-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            border: 1px solid;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .lp-wf-step-name {
            font-size: 12.5px;
            font-weight: 700;
            color: rgba(255,255,255,0.75);
            text-align: center;
        }

        .lp-wf-step-desc {
            font-size: 11px;
            color: rgba(255,255,255,0.28);
            text-align: center;
            line-height: 1.5;
        }

        .lp-wf-arrow {
            font-size: 18px;
            color: rgba(255,255,255,0.15);
            margin-top: -20px;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 900px) {
            .lp-hero {
                grid-template-columns: 1fr;
                padding: 30px 20px;
                gap: 28px;
            }

            .lp-nav {
                padding: 14px 20px;
            }

            .lp-workflow {
                padding: 30px 20px 50px;
            }

            .lp-h1 {
                font-size: 30px;
            }

            .lp-wf-arrow {
                display: none;
            }

            .lp-wf-steps {
                gap: 16px;
            }

            .lp-wf-step {
                width: 130px;
            }

            .lp-db-stats {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width: 500px) {
            .lp-h1 {
                font-size: 26px;
            }

            .lp-trust {
                flex-wrap: wrap;
                gap: 12px;
            }

            .lp-cta-row {
                flex-direction: column;
            }

            .lp-btn-primary, .lp-btn-ghost {
                width: 100%;
                justify-content: center;
            }
        }

        /* ── REKLAMLAŞTIRILMIŞ AKIŞ STİLLERİ ── */
        .lp-ad-container {
            padding: 30px 24px;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

