@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["PageTitle"] = "Ana Sayfa";
    Layout = "_Layout";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
        <img src="~/imgs/BirFikrimVar.png"
             alt="Bir Fikrim Var"
             style="width:42px; height:42px; border-radius:10px; object-fit:cover; border:1px solid #f0f0f0;" />
        <div>
            <div style="font-size:16px; font-weight:800; color:#111827; letter-spacing:-0.02em;">
                Hoş geldin, @User.Identity?.Name 👋
            </div>
            <div style="font-size:12px; color:#9ca3af; margin-top:1px;">
                İşte fikir sisteminin genel durumu
            </div>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-icon si-orange">💡</div>
                <span class="stat-trend up">+6</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">48</div>
                <div class="stat-label">Toplam Fikir</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-icon si-blue">⏳</div>
                <span class="stat-trend warn">Bekliyor</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">12</div>
                <div class="stat-label">Ön Onay Bekleyen</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-icon si-violet">📋</div>
                <span class="stat-trend warn">Bekliyor</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">7</div>
                <div class="stat-label">Komisyon Bekleyen</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-icon si-green">✅</div>
                <span class="stat-trend up">%48</span>
            </div>
            <div class="stat-card-bottom">
                <div class="stat-value">23</div>
                <div class="stat-label">Onaylanan Fikirler</div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <span class="card-header-title">Son Fikirler</span>
            <a asp-controller="Ideas" asp-action="Index" class="btn-table">Tümünü gör →</a>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="td-primary">Üretim sürecinde enerji tasarrufu</td>
                    <td class="td-muted">Operasyon</td>
                    <td class="td-muted">08.05.25</td>
                    <td><span class="badge badge-on-bekliyor">Ön Onay Bekliyor</span></td>
                    <td><a href="#" class="btn-table">Detay</a></td>
                </tr>
                <tr>
                    <td class="td-primary">Müşteri geri bildirim sistemi</td>
                    <td class="td-muted">Müşteri Deneyimi</td>
                    <td class="td-muted">06.05.25</td>
                    <td><span class="badge badge-kom-onaylı">Komisyon Onaylı</span></td>
                    <td><a href="#" class="btn-table">Detay</a></td>
                </tr>
                <tr>
                    <td class="td-primary">Depo otomasyon önerisi</td>
                    <td class="td-muted">Lojistik</td>
                    <td class="td-muted">01.05.25</td>
                    <td><span class="badge badge-taslak">Taslak</span></td>
                    <td><a href="#" class="btn-table">Detay</a></td>
                </tr>
            </tbody>
        </table>
    </div>
}
else
{
    <div class="lp-root">

        @* Arkaplan grid *@
        <div class="lp-grid-bg"></div>
        <div class="lp-glow-1"></div>
        <div class="lp-glow-2"></div>

        @* NAV *@
        <nav class="lp-nav">
            <div class="lp-nav-brand">
                <img src="~/imgs/BirFikrimVar.png" alt="Logo" class="lp-nav-logo" />
                <span class="lp-nav-name">Bir Fikrim Var</span>
            </div>
            <div class="lp-nav-actions">
                <a asp-controller="Account" asp-action="Giris" class="lp-nav-link">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Kayit" class="lp-nav-cta">Kayıt Ol</a>
            </div>
        </nav>

        @* HERO *@
        <section class="lp-hero">

            @* Sol: metin *@
            <div class="lp-hero-left">
                <div class="lp-badge">
                    <span class="lp-badge-dot"></span>
                    Kurumsal İnovasyon Platformu
                </div>

                <h1 class="lp-h1">
                    Fikirleri<br />
                    <span class="lp-h1-accent">Gerçeğe</span><br />
                    Dönüştürün
                </h1>

                <p class="lp-desc">
                    Çalışanlarınızın fikirlerini sistematik olarak toplayın,
                    değerlendirin ve onay süreçleriyle projeye dönüştürün.
                </p>

                <div class="lp-cta-row">
                    <a asp-controller="Account" asp-action="Giris" class="lp-btn-primary">
                        Platforma Giriş Yap
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                    <a asp-controller="Account" asp-action="Kayit" class="lp-btn-ghost">
                        Hesap Oluştur
                    </a>
                </div>

                <div class="lp-trust">
                    <div class="lp-trust-item">
                        <span class="lp-trust-val">1.2K+</span>
                        <span class="lp-trust-label">Fikir Gönderildi</span>
                    </div>
                    <div class="lp-trust-div"></div>
                    <div class="lp-trust-item">
                        <span class="lp-trust-val">%68</span>
                        <span class="lp-trust-label">Onay Oranı</span>
                    </div>
                    <div class="lp-trust-div"></div>
                    <div class="lp-trust-item">
                        <span class="lp-trust-val">24</span>
                        <span class="lp-trust-label">Aktif Departman</span>
                    </div>
                </div>
            </div>

            @* Sağ: dashboard preview *@
            <div class="lp-hero-right">
                <div class="lp-dashboard">

                    @* Mini topbar *@
                    <div class="lp-db-topbar">
                        <div class="lp-db-dots">
                            <span class="lp-dot lp-dot-red"></span>
                            <span class="lp-dot lp-dot-yellow"></span>
                            <span class="lp-dot lp-dot-green"></span>
                        </div>
                        <span class="lp-db-title">Dashboard — Bir Fikrim Var</span>
                    </div>

                    @* Mini stat row *@
                    <div class="lp-db-stats">
                        <div class="lp-db-stat">
                            <div class="lp-db-stat-val" style="color:#38bdf8;">48</div>
                            <div class="lp-db-stat-label">Toplam Fikir</div>
                        </div>
                        <div class="lp-db-stat">
                            <div class="lp-db-stat-val" style="color:#fb923c;">12</div>
                            <div class="lp-db-stat-label">Bekleyen</div>
                        </div>
                        <div class="lp-db-stat">
                            <div class="lp-db-stat-val" style="color:#34d399;">23</div>
                            <div class="lp-db-stat-label">Onaylanan</div>
                        </div>
                        <div class="lp-db-stat">
                            <div class="lp-db-stat-val" style="color:#a78bfa;">7</div>
                            <div class="lp-db-stat-label">Komisyon</div>
                        </div>
                    </div>

                    @* Fikir kartları *@
                    <div class="lp-db-label">Son Fikirler</div>

                    <div class="lp-idea-card">
                        <div class="lp-idea-left">
                            <div class="lp-idea-title">Üretimde Enerji Tasarrufu</div>
                            <div class="lp-idea-meta">Operasyon · Ayşe Kaya</div>
                        </div>
                        <span class="lp-idea-badge" style="background:rgba(59,130,246,0.15);color:#60a5fa;">Ön Onay</span>
                    </div>

                    <div class="lp-idea-card">
                        <div class="lp-idea-left">
                            <div class="lp-idea-title">Müşteri Geri Bildirim Sistemi</div>
                            <div class="lp-idea-meta">Müşteri Deneyimi · Mert Demir</div>
                        </div>
                        <span class="lp-idea-badge" style="background:rgba(52,211,153,0.15);color:#34d399;">Onaylı</span>
                    </div>

                    <div class="lp-idea-card">
                        <div class="lp-idea-left">
                            <div class="lp-idea-title">Depo Otomasyon Önerisi</div>
                            <div class="lp-idea-meta">Lojistik · Can Öztürk</div>
                        </div>
                        <span class="lp-idea-badge" style="background:rgba(167,139,250,0.15);color:#a78bfa;">Komisyon</span>
                    </div>

                    @* Progress bar *@
                    <div class="lp-db-progress-wrap">
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                            <span style="font-size:10px;color:rgba(255,255,255,0.4);">Bu ay onay oranı</span>
                            <span style="font-size:10px;color:#34d399;font-weight:700;">%68</span>
                        </div>
                        <div class="lp-db-progress-track">
                            <div class="lp-db-progress-fill"></div>
                        </div>
                    </div>

                </div>
            </div>

        </section>

        @* WORKFLOW *@
        <section class="lp-workflow">
            <div class="lp-wf-title">Nasıl Çalışır?</div>
            <div class="lp-wf-steps">
                <div class="lp-wf-step">
                    <div class="lp-wf-icon" style="background:rgba(56,189,248,0.1);border-color:rgba(56,189,248,0.2);">💡</div>
                    <div class="lp-wf-step-name">Fikir Oluştur</div>
                    <div class="lp-wf-step-desc">Çalışan fikir girer, SWOT doldurur</div>
                </div>
                <div class="lp-wf-arrow">→</div>
                <div class="lp-wf-step">
                    <div class="lp-wf-icon" style="background:rgba(251,146,60,0.1);border-color:rgba(251,146,60,0.2);">🔍</div>
                    <div class="lp-wf-step-name">Ön Değerlendirme</div>
                    <div class="lp-wf-step-desc">Ön onaycı inceler ve puanlar</div>
                </div>
                <div class="lp-wf-arrow">→</div>
                <div class="lp-wf-step">
                    <div class="lp-wf-icon" style="background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.2);">⭐</div>
                    <div class="lp-wf-step-name">Komisyon Onayı</div>
                    <div class="lp-wf-step-desc">Komisyon detaylı değerlendirir</div>
                </div>
                <div class="lp-wf-arrow">→</div>
                <div class="lp-wf-step">
                    <div class="lp-wf-icon" style="background:rgba(52,211,153,0.1);border-color:rgba(52,211,153,0.2);">🚀</div>
                    <div class="lp-wf-step-name">Projeye Dönüşüm</div>
                    <div class="lp-wf-step-desc">Onaylanan fikir hayata geçer</div>
                </div>
            </div>
        </section>

    </div>

    <style>
        body {
            overflow-x: hidden !important;
        }

        /* ── ROOT ── */
        .lp-root {
            min-height: 100vh;
            width: 100vw;
            background: #070b18;
            position: relative;
            overflow-x: hidden;
            font-family: -apple-system, 'Segoe UI', system-ui, sans-serif;
        }

        /* ── ARKAPLAN ── */
        .lp-grid-bg {
            position: fixed;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.028) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.028) 1px, transparent 1px);
            background-size: 48px 48px;
            z-index: 0;
            pointer-events: none;
        }

        .lp-glow-1 {
            position: fixed;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
            top: -150px;
            right: -100px;
            pointer-events: none;
            z-index: 0;
        }

        .lp-glow-2 {
            position: fixed;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(249,115,22,0.07) 0%, transparent 70%);
            bottom: -100px;
            left: -100px;
            pointer-events: none;
            z-index: 0;
        }

        /* ── NAV ── */
        .lp-nav {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 40px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .lp-nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .lp-nav-logo {
            width: 32px;
            height: 32px;
            object-fit: contain;
            filter: drop-shadow(0 0 6px rgba(56,189,248,0.3));
        }

        .lp-nav-name {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .lp-nav-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .lp-nav-link {
            font-size: 13.5px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.15s;
        }

            .lp-nav-link:hover {
                color: #fff;
            }

        .lp-nav-cta {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            padding: 7px 18px;
            border-radius: 6px;
            text-decoration: none;
            transition: background 0.15s;
        }

            .lp-nav-cta:hover {
                background: rgba(255,255,255,0.13);
                color: #fff;
            }

        /* ── HERO ── */
        .lp-hero {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
            padding: 50px 40px 40px;
            max-width: 100%;
            margin: 0 auto;
            box-sizing: border-box;
        }

        /* Sol */
        .lp-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11.5px;
            font-weight: 600;
            color: rgba(56,189,248,0.85);
            background: rgba(56,189,248,0.08);
            border: 1px solid rgba(56,189,248,0.18);
            padding: 5px 12px;
            border-radius: 20px;
            margin-bottom: 22px;
            letter-spacing: 0.02em;
        }

        .lp-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #38bdf8;
            animation: blink 2s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }

        .lp-h1 {
            font-size: 48px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.04em;
            line-height: 1.08;
            margin: 0 0 18px;
        }

        .lp-h1-accent {
            background: linear-gradient(135deg, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .lp-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.42);
            line-height: 1.7;
            margin: 0 0 26px;
            max-width: 100%;
        }

        .lp-cta-row {
            display: flex;
            gap: 10px;
            margin-bottom: 36px;
            flex-wrap: wrap;
        }

        .lp-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 26px;
            background: #f97316;
            color: #fff;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.15s, transform 0.15s;
            letter-spacing: -0.01em;
        }

            .lp-btn-primary:hover {
                background: #ea6c0a;
                color: #fff;
                transform: translateY(-1px);
            }

        .lp-btn-ghost {
            display: inline-flex;
            align-items: center;
            padding: 12px 26px;
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.15s;
        }

            .lp-btn-ghost:hover {
                background: rgba(255,255,255,0.09);
                color: #fff;
            }

        .lp-trust {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .lp-trust-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .lp-trust-val {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .lp-trust-label {
            font-size: 11px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-trust-div {
            width: 1px;
            height: 28px;
            background: rgba(255,255,255,0.1);
        }

        /* Sağ: dashboard preview */
        .lp-dashboard {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            overflow: hidden;
            backdrop-filter: blur(12px);
            box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 24px 64px rgba(0,0,0,0.4);
        }

        .lp-db-topbar {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            background: rgba(255,255,255,0.02);
        }

        .lp-db-dots {
            display: flex;
            gap: 5px;
        }

        .lp-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
        }

        .lp-dot-red {
            background: #ef4444;
        }

        .lp-dot-yellow {
            background: #f59e0b;
        }

        .lp-dot-green {
            background: #22c55e;
        }

        .lp-db-title {
            font-size: 11px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-db-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .lp-db-stat {
            padding: 14px 12px;
            border-right: 1px solid rgba(255,255,255,0.06);
            text-align: center;
        }

            .lp-db-stat:last-child {
                border-right: none;
            }

        .lp-db-stat-val {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1;
            margin-bottom: 4px;
        }

        .lp-db-stat-label {
            font-size: 9.5px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }

        .lp-db-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: rgba(255,255,255,0.25);
            padding: 12px 14px 6px;
        }

        .lp-idea-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 9px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.12s;
        }

            .lp-idea-card:hover {
                background: rgba(255,255,255,0.03);
            }

        .lp-idea-title {
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.8);
            margin-bottom: 2px;
        }

        .lp-idea-meta {
            font-size: 10.5px;
            color: rgba(255,255,255,0.28);
        }

        .lp-idea-badge {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 5px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .lp-db-progress-wrap {
            padding: 12px 14px 14px;
        }

        .lp-db-progress-track {
            height: 4px;
            background: rgba(255,255,255,0.07);
            border-radius: 4px;
            overflow: hidden;
        }

        .lp-db-progress-fill {
            height: 100%;
            width: 68%;
            background: linear-gradient(90deg, #38bdf8, #818cf8);
            border-radius: 4px;
        }

        /* ── WORKFLOW ── */
        .lp-workflow {
            position: relative;
            z-index: 1;
            padding: 40px 40px 60px;
            max-width: 100%;
            margin: 0 auto;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .lp-wf-title {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.25);
            margin-bottom: 28px;
            text-align: center;
        }

        .lp-wf-steps {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .lp-wf-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            width: 160px;
        }

        .lp-wf-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            border: 1px solid;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .lp-wf-step-name {
            font-size: 12.5px;
            font-weight: 700;
            color: rgba(255,255,255,0.75);
            text-align: center;
        }

        .lp-wf-step-desc {
            font-size: 11px;
            color: rgba(255,255,255,0.28);
            text-align: center;
            line-height: 1.5;
        }

        .lp-wf-arrow {
            font-size: 18px;
            color: rgba(255,255,255,0.15);
            margin-top: -20px;
        }

        /* ── RESPONSIVE ── */
