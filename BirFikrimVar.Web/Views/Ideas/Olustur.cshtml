@model BirFikrimVar.Web.Models.FikirOlusturViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Fikir Oluştur";
}
<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-lightbulb"></i> Yeni Fikir Paylaş</h4>
        </div>
        <div class="card-body">
            <form asp-action="Olustur" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Baslik" class="form-label fw-bold">Fikir Başlığı</label>
                    <input asp-for="Baslik" class="form-control" placeholder="Fikrinize kısa bir isim verin" />
                    <span asp-validation-for="Baslik" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Ozet" class="form-label fw-bold">Özet</label>
                        <textarea asp-for="Ozet" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Kapsam" class="form-label fw-bold">Kapsam</label>
                        <textarea asp-for="Kapsam" class="form-control" rows="3" placeholder="Hangi birimleri kapsıyor?"></textarea>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="YenilikciYan" class="form-label fw-bold">Yenilikçi Yanı</label>
                    <textarea asp-for="YenilikciYan" class="form-control" rows="2"></textarea>
                </div>

                <h5 class="border-bottom pb-2 mt-4 text-secondary">SWOT Analizi</h5>
                <div class="row">
                    <div class="col-md-6 mb-3 text-success">
                        <label asp-for="GucluYonler" class="form-label fw-bold">Güçlü Yönler (Strengths)</label>
                        <textarea asp-for="GucluYonler" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6 mb-3 text-danger">
                        <label asp-for="ZayifYonler" class="form-label fw-bold">Zayıf Yönler (Weaknesses)</label>
                        <textarea asp-for="ZayifYonler" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6 mb-3 text-info">
                        <label asp-for="Firsatlar" class="form-label fw-bold">Fırsatlar (Opportunities)</label>
                        <textarea asp-for="Firsatlar" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6 mb-3 text-warning">
                        <label asp-for="Tehditler" class="form-label fw-bold">Tehditler (Threats)</label>
                        <textarea asp-for="Tehditler" class="form-control"></textarea>
                    </div>
                </div>

                <div class="mb-4 mt-3">
                    <label class="form-label fw-bold">Ek Dosyalar (PDF, Görsel, Word - Max 5MB)</label>
                    <input type="file" name="Dosyalar" class="form-control" multiple />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                    <button type="submit" class="btn btn-success px-5">Taslak Olarak Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
