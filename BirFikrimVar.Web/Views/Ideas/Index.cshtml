@model IEnumerable<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Fikirlerim";
    ViewData["PageTitle"] = "Fikirlerim";
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-collection me-2" style="color:#9ca3af;"></i>Fikirlerim
        </span>
        <a asp-action="Olustur"
           class="btn-table"
           style="color:#15803d; border-color:#d1fae5; background:#f0fdf4;">
            <i class="bi bi-plus me-1"></i>Yeni Fikir
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
            <div class="d-flex align-items-center gap-2">
                <div style="position: relative; width: 220px;">
                    <select id="clientDurumFiltre"
                            class="form-select"
                            style="font-size: 13px; border-color: #d1d5db; border-radius: 6px; padding: 6px 12px; width: 100%;"
                            onchange="fikirleriFiltreleVeSirala()">
                        <option value="TUMU">Tüm Durumlar</option>
                        <option value="Taslak">Taslak</option>
                        <option value="OnOnayBekliyor">Ön Onay Bekliyor</option>
                        <option value="OnOnayRetli">Ön Onay Retli</option>
                        <option value="KomisyonOnayiBekliyor">Komisyon Bekliyor</option>
                        <option value="KomisyonOnayli">Komisyon Onaylı</option>
                        <option value="KomisyonOnayiRetli">Komisyon Retli</option>
                    </select>
                </div>
            </div>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th style="width:110px;">Tarih</th>
                    <th style="width:160px;">Durum</th>
                    <th style="width:160px; text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody id="fikirTabloGv">
                @foreach (var item in Model)
                {
                    var (badgeClass, badgeLabel) = item.Durum switch
                    {
                        "Taslak" => ("badge-taslak", "Taslak"),
                        "OnOnayBekliyor" => ("badge-on-bekliyor", "Ön Onay Bekliyor"),
                        "OnOnayRetli" => ("badge-on-retli", "Ön Onay Retli"),
                        "KomisyonOnayiBekliyor" => ("badge-kom-bekliyor", "Komisyon Bekliyor"),
                        "KomisyonOnayli" => ("badge-kom-onaylı", "Komisyon Onaylı"),
                        "KomisyonOnayiRetli" => ("badge-kom-retli", "Komisyon Retli"),
                        _ => ("badge-taslak", item.Durum)
                    };

                    <tr data-durum="@item.Durum" data-tarih="@item.OlusturmaTarihi.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="td-primary">@item.Baslik</td>
                        <td class="td-muted">@item.OlusturmaTarihi.ToShortDateString()</td>
                        <td><span class="badge @badgeClass">@badgeLabel</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex; gap:6px; justify-content:flex-end;">
                                @if (item.Durum == "Taslak")
                                {
                                    <form asp-action="OnOnayaGonder"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          style="display:inline;">
                                        <button type="submit"
                                                class="btn-table"
                                                style="color:#15803d; border-color:#d1fae5; background:#f0fdf4;">
                                            <i class="bi bi-send me-1"></i>Ön Onaya Gönder
                                        </button>
                                    </form>
                                }
                                <a asp-action="Detay"
                                   asp-route-id="@item.Id"
                                   class="btn-table">
                                    <i class="bi bi-eye me-1"></i>Detay
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:48px 20px; text-align:center;">
            <div style="width:44px; height:44px; border-radius:10px; background:#fff7ed; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
                <i class="bi bi-lightbulb" style="font-size:20px; color:#f97316;"></i>
            </div>
            <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
                Henüz fikir eklemediniz
            </div>
            <div style="font-size:12.5px; color:#9ca3af; margin-bottom:16px;">
                İlk fikrinizi ekleyerek süreci başlatın.
            </div>
            <a asp-action="Olustur"
               class="btn-table"
               style="color:#15803d; border-color:#d1fae5; background:#f0fdf4; display:inline-flex; align-items:center; gap:5px;">
                <i class="bi bi-plus"></i>Yeni Fikir Oluştur
            </a>
        </div>
    }
    <div id="jsBosUyarisi" style="padding:48px 20px; text-align:center; display:none;">
        <div style="width:44px; height:44px; border-radius:10px; background:#fff7ed; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
            <i class="bi bi-search" style="font-size:20px; color:#f97316;"></i>
        </div>
        <div style="font-size:13.5px; font-weight:600; color:#111827; margin-bottom:4px;">
            Aranan kritere uygun fikir bulunamadı
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        fikirleriFiltreleVeSirala();
    });

    function fikirleriFiltreleVeSirala() {
        const tbody = document.getElementById("fikirTabloGv");
        if (!tbody) return;

        const secilenDurum = document.getElementById("clientDurumFiltre").value;
        const satirlar = Array.from(tbody.querySelectorAll("tr"));
        let gorunurSatirSayisi = 0;


        satirlar.sort((a, b) => {
            const tarihA = new Date(a.getAttribute("data-tarih"));
            const tarihB = new Date(b.getAttribute("data-tarih"));
            return tarihB - tarihA;
        });

        satirlar.forEach(satir => {
            const satirDurum = satir.getAttribute("data-durum");

            if (secilenDurum === "TUMU" || satirDurum === secilenDurum) {
                satir.style.display = "";
                gorunurSatirSayisi++;
            } else {
                satir.style.display = "none";
            }
            tbody.appendChild(satir);
        });

        const bosUyarisi = document.getElementById("jsBosUyarisi");
        if (gorunurSatirSayisi === 0) {
            bosUyarisi.style.display = "block";
        } else {
            bosUyarisi.style.display = "none";
        }
    }
</script>