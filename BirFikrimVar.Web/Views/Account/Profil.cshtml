@model BirFikrimVar.Web.Models.ProfilGuncelleViewModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-person-gear me-2"></i>Profil Ayarlarım</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Profil" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad</label>
                            <input asp-for="Ad" class="form-control" />
                            <span asp-validation-for="Ad" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad</label>
                            <input asp-for="Ad" class="form-control" placeholder="Adınız" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Soyad</label>
                            <input asp-for="Soyad" class="form-control" placeholder="Soyadınız" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">E-posta</label>
                            <input asp-for="Email" class="form-control" />
                        </div>

                        <hr />
                        <p class="text-muted small">Şifrenizi değiştirmek istemiyorsanız aşağıdaki alanları boş bırakın.</p>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mevcut Şifre</label>
                            <input asp-for="MevcutParola" type="password" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Yeni Şifre</label>
                            <input asp-for="YeniParola" type="password" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Yeni Şifre Tekrar</label>
                            <input asp-for="YeniParolaTekrar" type="password" class="form-control" />
                            <span asp-validation-for="YeniParolaTekrar" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Bilgileri Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
