@model BirFikrimVar.Web.Models.GirisViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_Layout";
}

<div class="landing-page">
    <canvas id="bgCanvas"></canvas>

    <div class="auth-inner">

        @if (TempData["DevModeOnayLinki"] != null)
        {
            <div style="background:rgba(251,146,60,0.12); border:1px solid rgba(249,115,22,0.25); border-radius:8px; padding:12px 14px; margin-bottom:20px; display:flex; gap:10px; align-items:flex-start; text-align:left;">
                <span style="font-size:15px; flex-shrink:0;">🛠</span>
                <div>
                    <div style="font-size:11.5px; font-weight:700; color:#f97316; margin-bottom:3px;">Geliştirici Test Modu</div>
                    <div style="font-size:11px; color:rgba(255,255,255,0.45); margin-bottom:8px;">
                        E-posta doğrulama simülasyonu için butonu kullanın.
                    </div>
                    <a href="@TempData["DevModeOnayLinki"]"
                       style="font-size:11.5px; font-weight:600; color:#f97316; background:rgba(249,115,22,0.15); border:1px solid rgba(249,115,22,0.3); padding:4px 12px; border-radius:5px; text-decoration:none; display:inline-flex; align-items:center; gap:5px;">
                        ✉ E-postayı Doğrula
                    </a>
                </div>
            </div>
        }

        <div class="auth-logo-wrap">
            <img src="~/imgs/BirFikrimVar.png" alt="Logo" class="auth-logo-img" />
        </div>

        <h1 class="auth-heading">Hoş Geldiniz</h1>
        <p class="auth-subtext">Hesabınıza giriş yapın</p>

        <form asp-action="Giris" method="post" novalidate style="width:100%;">
            <div asp-validation-summary="ModelOnly"
                 style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.25); border-radius:6px; padding:10px 12px; font-size:12px; color:#fca5a5; margin-bottom:16px;"></div>

            <div style="margin-bottom:14px;">
                <label asp-for="Email" class="auth-label">E-posta</label>
                <input asp-for="Email"
                       class="auth-input"
                       placeholder="ornek@sirket.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="auth-err"></span>
            </div>

            <div style="margin-bottom:22px;">
                <label asp-for="Parola" class="auth-label">Parola</label>
                <div style="position:relative;">
                    <input asp-for="Parola"
                           type="password"
                           class="auth-input"
                           placeholder="••••••••"
                           id="parola-input"
                           autocomplete="current-password"
                           style="padding-right:42px;" />
                    <button type="button"
                            id="toggle-password"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.3);font-size:15px;padding:0;display:flex;align-items:center;">
                        <i class="bi bi-eye-slash" id="toggle-icon"></i>
                    </button>
                </div>
                <span asp-validation-for="Parola" class="auth-err"></span>
            </div>

            <button type="submit" class="auth-submit">
                Giriş Yap
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
            </button>
        </form>

        <div class="auth-footer-text">
            Hesabınız yok mu?
            <a asp-controller="Account" asp-action="Kayit" class="auth-footer-link">Kayıt Ol</a>
        </div>

        <div class="auth-info">
            <i class="bi bi-shield-check" style="font-size:12px;"></i>
            Giriş için e-posta doğrulaması gereklidir.
        </div>

    </div>
</div>

<style>
    body {
        overflow: hidden !important;
    }

    .landing-page {
        position: fixed;
        inset: 0;
        background: #080b12;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #bgCanvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    .auth-inner {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 400px;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 36px 32px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        backdrop-filter: blur(12px);
    }

    .auth-logo-wrap {
        width: 72px;
        height: 72px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        margin-bottom: 20px;
        background: radial-gradient(circle, rgba(249,115,22,0.12) 0%, rgba(0,0,0,0) 75%);
        border: 1px solid rgba(249,115,22,0.22);
        box-shadow: 0 0 0 8px rgba(249,115,22,0.05);
    }

    .auth-logo-img {
        width: 250%;
        height: 250%;
        object-fit: contain;
        filter: drop-shadow(0 0 10px rgba(249,115,22,0.3));
    }

    .auth-heading {
        font-size: 22px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
        margin: 0 0 6px;
    }

    .auth-subtext {
        font-size: 13px;
        color: rgba(255,255,255,0.38);
        margin: 0 0 24px;
    }

    .auth-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        margin-bottom: 6px;
        letter-spacing: 0.02em;
    }

    .auth-input {
        width: 100%;
        padding: 10px 14px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        font-size: 13.5px;
        color: #ffffff;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        font-family: inherit;
    }

        .auth-input::placeholder {
            color: rgba(255,255,255,0.2);
        }

        .auth-input:focus {
            border-color: rgba(249,115,22,0.5);
            box-shadow: 0 0 0 3px rgba(249,115,22,0.12);
        }

    .auth-err {
        font-size: 11.5px;
        color: #fca5a5;
        margin-top: 4px;
        display: block;
    }

    .auth-submit {
        width: 100%;
        padding: 12px;
        background: #f97316;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.15s, transform 0.15s;
        font-family: inherit;
        letter-spacing: -0.01em;
    }

        .auth-submit:hover {
            background: #ea6c0a;
            transform: translateY(-1px);
        }

    .auth-footer-text {
        margin-top: 20px;
        font-size: 12.5px;
        color: rgba(255,255,255,0.3);
    }

    .auth-footer-link {
        color: #f97316;
        font-weight: 700;
        text-decoration: none;
        margin-left: 4px;
    }

        .auth-footer-link:hover {
            color: #ea6c0a;
        }

    .auth-info {
        margin-top: 14px;
        font-size: 11px;
        color: rgba(255,255,255,0.18);
        display: flex;
        align-items: center;
        gap: 5px;
    }
</style>

<script>
    (function () {
        var canvas = document.getElementById('bgCanvas');
        var ctx = canvas.getContext('2d');
        var particles = [];
        var W, H;

        function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
        function rand(a, b) { return Math.random() * (b - a) + a; }
        function mkp() { return { x: rand(0, W), y: rand(0, H), r: rand(0.8, 2.2), vx: rand(-0.12, 0.12), vy: rand(-0.28, -0.06), alpha: rand(0.15, 0.5) }; }

        function init() { resize(); particles = []; for (var i = 0; i < 120; i++) particles.push(mkp()); }

        function draw() {
            ctx.clearRect(0, 0, W, H);
            particles.forEach(function (p) {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(249,115,22,' + p.alpha + ')';
                ctx.fill();
                p.x += p.vx; p.y += p.vy;
                if (p.y < -4) { p.y = H + 4; p.x = rand(0, W); }
                if (p.x < -4) p.x = W + 4;
                if (p.x > W + 4) p.x = -4;
            });
            requestAnimationFrame(draw);
        }

        window.addEventListener('resize', resize);
        init(); draw();
    }());

    document.getElementById('toggle-password').addEventListener('click', function () {
        var input = document.getElementById('parola-input');
        var icon = document.getElementById('toggle-icon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}