@model BirFikrimVar.Web.Models.GirisViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_Layout";
}

<div class="lp-root">
    <div class="lp-grid-bg"></div>
    <div class="lp-glow-1"></div>
    <div class="lp-glow-2"></div>

    <nav class="lp-nav">
        
        <div class="lp-nav-actions">
            <span style="font-size:13px; color:rgba(255,255,255,0.35);">Hesabın yok mu?</span>
            <a asp-action="Kayit" class="lp-nav-cta">Kayıt Ol</a>
        </div>
    </nav>

    <div class="auth-center">
        <div class="auth-card">

            <div class="auth-card-logo">
                <img src="~/imgs/BirFikrimVar.png" alt="Logo" class="auth-card-logo-img" />
            </div>

            <h1 class="auth-card-title">Tekrar Hoş Geldiniz</h1>
            <p class="auth-card-sub">Hesabınıza giriş yaparak devam edin</p>

            @if (TempData["DevModeOnayLinki"] != null)
            {
                <div class="auth-dev-banner">
                    <span style="font-size:14px;">🛠</span>
                    <div>
                        <div style="font-size:11.5px; font-weight:700; color:#fb923c; margin-bottom:3px;">Geliştirici Test Modu</div>
                        <div style="font-size:11px; color:rgba(255,255,255,0.4); margin-bottom:8px;">E-posta doğrulama simülasyonu</div>
                        <a href="@TempData["DevModeOnayLinki"]" class="auth-dev-btn">
                            ✉ E-postayı Doğrula
                        </a>
                    </div>
                </div>
            }

            <form asp-action="Giris" method="post" novalidate style="width:100%;">
                <div asp-validation-summary="ModelOnly" class="auth-error-box"></div>

                <div class="auth-field">
                    <label asp-for="Email" class="auth-label">E-posta</label>
                    <input asp-for="Email"
                           class="auth-input"
                           placeholder="ornek@sirket.com"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-err"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Parola" class="auth-label">Parola</label>
                    <div style="position:relative;">
                        <input asp-for="Parola"
                               type="password"
                               class="auth-input"
                               placeholder="••••••••"
                               id="parola-input"
                               autocomplete="current-password"
                               style="padding-right:42px;" />
                        <button type="button"
                                id="toggle-password"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.25);font-size:15px;padding:0;">
                            <i class="bi bi-eye-slash" id="toggle-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Parola" class="auth-err"></span>
                </div>

                <button type="submit" class="auth-submit">
                    Giriş Yap
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </button>
            </form>

            <div class="auth-footer">
                Hesabınız yok mu?
                <a asp-action="Kayit" class="auth-footer-link">Kayıt Ol</a>
            </div>

            <div class="auth-info">
                <i class="bi bi-shield-check"></i>
                Giriş için e-posta doğrulaması gereklidir.
            </div>

        </div>
    </div>
</div>

<style>
    body {
        overflow-x: hidden !important;
    }

    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
    }

    .lp-root {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #070b18;
        position: relative;
        overflow-x: hidden;
    }

    .lp-grid-bg {
        position: fixed;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,0.028) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.028) 1px, transparent 1px);
        background-size: 48px 48px;
        z-index: 0;
        pointer-events: none;
    }

    .lp-glow-1 {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
        top: -150px;
        right: -100px;
        pointer-events: none;
        z-index: 0;
    }

    .lp-glow-2 {
        position: fixed;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(249,115,22,0.07) 0%, transparent 70%);
        bottom: -100px;
        left: -100px;
        pointer-events: none;
        z-index: 0;
    }

    .lp-nav {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 40px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .lp-nav-logo {
        width: 200px; /* 50px'den 75px'e çıkarıldı */
        height: 200px; /* Kare formunu korumak için yükseklik de artırıldı */
        object-fit: contain;
        filter: drop-shadow(0 0 8px rgba(56,189,248,0.4)); /* Parlama efekti biraz güçlendirildi */
        margin-top: -5px; /* Logonun büyüklüğünden dolayı yazı aşağıda kalmasın diye hafif yukarı çekildi */
    }

    .lp-nav-brand {
        display: flex;
        align-items: center;
        gap: 5px; /* Logo ile yazı arasındaki boşluğu biraz açtık */
        text-decoration: none;
    }

    .lp-nav-name {
        font-size: 17px;
        font-weight: 700;
        color: #fff;
        letter-spacing: -0.02em;
    }

    .lp-nav-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .lp-nav-cta {
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        padding: 7px 18px;
        border-radius: 6px;
        text-decoration: none;
        transition: background 0.15s;
    }

        .lp-nav-cta:hover {
            background: rgba(255,255,255,0.13);
            color: #fff;
        }

    .auth-center {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center; /* Dikey ortalama */
        justify-content: center; /* Yatay ortalama */
        flex: 1; /* Tüm boşluğu kapla */
        padding: 20px;
        box-sizing: border-box;
    }

    .auth-card {
        width: 100%;
        max-width: 360px; /* 420px'den 360px'e çekerek kartı daralttık */
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 24px; /* 36px'den düşürerek kartı dikeyde de küçülttük */
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        box-shadow: 0 24px 64px rgba(0,0,0,0.4);
        margin-top: -10px;
    }

    .auth-card-logo {
        width: 90px; 
        height: 90px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        margin-bottom: 16px;
        background: rgba(56,189,248,0.07);
        border: 1px solid rgba(56,189,248,0.15);
        overflow: hidden; 
    }

    .auth-card-logo-img {
        width: 100%;
        height: 100%; 
        object-fit: contain; 
        
        transform: scale(1.9);
        filter: drop-shadow(0 0 12px rgba(56,189,248,0.7));
    }

    .auth-card-title {
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        margin: 0 0 6px;
        text-align: center;
    }

    .auth-card-sub {
        font-size: 13px;
        color: rgba(255,255,255,0.35);
        margin: 0 0 24px;
        text-align: center;
    }

    .auth-dev-banner {
        width: 100%;
        background: rgba(251,146,60,0.08);
        border: 1px solid rgba(249,115,22,0.2);
        border-radius: 8px;
        padding: 12px 14px;
        margin-bottom: 20px;
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .auth-dev-btn {
        font-size: 11.5px;
        font-weight: 600;
        color: #fb923c;
        background: rgba(249,115,22,0.12);
        border: 1px solid rgba(249,115,22,0.25);
        padding: 4px 12px;
        border-radius: 5px;
        text-decoration: none;
        display: inline-block;
    }

    .auth-error-box {
        width: 100%;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.2);
        border-radius: 6px;
        padding: 10px 12px;
        font-size: 12.5px;
        color: #fca5a5;
        margin-bottom: 16px;
    }

        .auth-error-box:empty {
            display: none;
        }

    .auth-field {
        width: 100%;
        margin-bottom: 16px;
    }

    .auth-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.45);
        margin-bottom: 6px;
        letter-spacing: 0.02em;
    }

    .auth-input {
        width: 100%;
        padding: 10px 14px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 8px;
        font-size: 13.5px;
        color: #fff;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        font-family: inherit;
        box-sizing: border-box;
    }

        .auth-input::placeholder {
            color: rgba(255,255,255,0.18);
        }

        .auth-input:focus {
            border-color: rgba(56,189,248,0.4);
            box-shadow: 0 0 0 3px rgba(56,189,248,0.1);
        }

    .auth-err {
        font-size: 11.5px;
        color: #fca5a5;
        margin-top: 4px;
        display: block;
    }

    .auth-submit {
        width: 100%;
        padding: 12px;
        background: #f97316;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.15s, transform 0.15s;
        font-family: inherit;
        margin-top: 6px;
    }

        .auth-submit:hover {
            background: #ea6c0a;
            transform: translateY(-1px);
        }

    .auth-footer {
        margin-top: 20px;
        font-size: 12.5px;
        color: rgba(255,255,255,0.28);
        text-align: center;
    }

    .auth-footer-link {
        color: #38bdf8;
        font-weight: 600;
        text-decoration: none;
        margin-left: 4px;
    }

        .auth-footer-link:hover {
            color: #7dd3fc;
        }

    .auth-info {
        margin-top: 14px;
        font-size: 11px;
        color: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        gap: 5px;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('toggle-password').addEventListener('click', function () {
            var input = document.getElementById('parola-input');
            var icon = document.getElementById('toggle-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            }
        });
    </script>
}