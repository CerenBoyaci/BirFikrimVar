@model BirFikrimVar.Web.Models.GirisViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-shield-lock-fill me-2"></i>Kullanıcı Girişi</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Giris" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold">E-posta</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="E-posta adresiniz" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Parola" class="form-label small fw-bold">Parola</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                            <input asp-for="Parola" type="password" class="form-control" placeholder="Parolanız" />
                        </div>
                        <span asp-validation-for="Parola" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark py-2">Giriş Yap</button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <span class="small text-muted">Henüz kayıt olmadınız mı?</span>
                <a asp-action="Kayit" class="small fw-bold text-decoration-none ms-1">Hemen Kaydol</a>
            </div>
        </div>

        <div class="alert alert-info mt-4 small border-0 shadow-sm">
            <i class="bi bi-info-circle-fill me-2"></i>
            Giriş yapabilmek için e-posta adresinizi doğrulamış olmanız gerekmektedir.
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
