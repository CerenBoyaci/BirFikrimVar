@model BirFikrimVar.Web.Models.GirisViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="col-12 col-md-6 col-lg-5">

            @if (TempData["DevModeOnayLinki"] != null)
            {
                <div class="alert alert-warning shadow-sm border-start border-4 border-warning mb-4">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-tools fs-3"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Geliştirici Test Modu</h6>
                            <p class="small mb-2">Hesabı onaylamak için e-posta kutunuza gitmek yerine aşağıdaki simülasyon butonunu kullanabilirsiniz.</p>
                            <a href="@TempData["DevModeOnayLinki"]" class="btn btn-dark btn-sm rounded-pill px-3">
                                <i class="bi bi-envelope-check-fill me-1"></i> Simülasyon: E-postayı Doğrula
                            </a>
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 border-0 rounded-top-4">
                    <i class="bi bi-shield-lock fs-1 d-block mb-2"></i>
                    <h3 class="fw-bold mb-0">Hoş Geldiniz</h3>
                    <p class="text-white-50 small mb-0">Lütfen bilgilerinizi girerek oturum açın</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Giris" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control border-0 bg-light" id="floatingInput" placeholder="name@example.com">
                            <label asp-for="Email" class="text-muted">E-posta Adresi</label>

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Parola" type="password" class="form-control border-0 bg-light" id="floatingPassword" placeholder="Parola">
                            <label asp-for="Parola" class="text-muted">Parola</label>
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer"
                               id="toggle-password" style="z-index: 10; cursor: pointer;"></i>
                            <span asp-validation-for="Parola" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold shadow-sm rounded-3">
                                Giriş Yap <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center rounded-bottom-4">
                    <span class="text-muted small">Hesabınız yok mu?</span>
                    <a asp-action="Kayit" class="fw-bold text-primary text-decoration-none ms-1">Yeni Hesap Oluştur</a>
                </div>
            </div>

            <div class="text-center mt-4 px-3">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Giriş yapabilmek için e-posta adresinizi doğrulamış olmanız gerekmektedir.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
         
            const toggleIcons = document.querySelectorAll('.bi-eye-slash, .bi-eye, #toggle-password, .toggle-password-icon');

            toggleIcons.forEach(icon => {
                icon.addEventListener('click', function () {
                
                    const input = this.parentElement.querySelector('input');

                    if (input.type === "password") {
                        input.type = "text";
                        this.classList.remove("bi-eye-slash");
                        this.classList.add("bi-eye");
                    } else {
                        input.type = "password";
                        this.classList.remove("bi-eye");
                        this.classList.add("bi-eye-slash");
                    }
                });
            });
        });
    </script>
}