@model BirFikrimVar.Web.Models.KayitViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 85vh;">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                    <i class="bi bi-person-plus-fill fs-1 d-block mb-2"></i>
                    <h3 class="fw-bold mb-0">Yeni Hesap Oluştur</h3>
                    <p class="text-white-50 small mb-0">Fikirlerini paylaşmak için aramıza katıl</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Kayit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Ad" class="form-control border-0 bg-light" id="floatingAd" placeholder="Adınız">
                                    <label asp-for="Ad" class="text-muted">Ad</label>
                                    <span asp-validation-for="Ad" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Soyad" class="form-control border-0 bg-light" id="floatingSoyad" placeholder="Soyadınız">
                                    <label asp-for="Soyad" class="text-muted">Soyad</label>
                                    <span asp-validation-for="Soyad" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control border-0 bg-light" id="floatingEmail" placeholder="name@example.com">
                            <label asp-for="Email" class="text-muted">E-posta Adresi</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Parola" type="password" class="form-control border-0 bg-light" id="floatingParola" placeholder="Parola">
                                    <label asp-for="Parola" class="text-muted">Parola</label>
                                    <span asp-validation-for="Parola" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="form-floating">
                                    <input asp-for="ParolaTekrar" type="password" class="form-control border-0 bg-light" id="floatingParolaTekrar" placeholder="Parola Tekrar">
                                    <label asp-for="ParolaTekrar" class="text-muted">Parola Tekrar</label>
                                    <span asp-validation-for="ParolaTekrar" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg py-3 fw-bold shadow-sm rounded-3">
                                Hesap Oluştur <i class="bi bi-check-circle-fill ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center rounded-bottom-4">
                    <span class="text-muted small">Zaten hesabınız var mı?</span>
                    <a asp-action="Giris" class="fw-bold text-success text-decoration-none ms-1">Giriş Yap</a>
                </div>
            </div>

            <div class="text-center mt-4 mb-5">
                <p class="text-muted small px-4">
                    <i class="bi bi-info-circle me-1"></i>
                    Kayıt olduktan sonra e-posta adresinize bir doğrulama bağlantısı gönderilecektir.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}