@model List<System.Text.Json.JsonElement>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

@if (TempData["HataMesaji"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["HataMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 text-dark"><i class="bi bi-people-fill me-2"></i>Kullanıcı Yönetimi</h4>
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#yeniKullaniciModal">
        <i class="bi bi-person-plus-fill"></i> Yeni Kullanıcı Ekle
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Durum</th>
                    <th>Mevcut Rol</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var isAktif = user.GetProperty("aktifMi").GetBoolean();
                    <tr>
                        <td>@user.GetProperty("ad").GetString() @user.GetProperty("soyad").GetString()</td>
                        <td>@user.GetProperty("email").GetString()</td>
                        <td>
                            @if (isAktif)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @string.Join(", ", user.GetProperty("roller").EnumerateArray().Select(r => r.GetString()))
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <!-- Rol Güncelleme Formu -->
                                <form asp-action="RolGuncelle" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="userId" value="@user.GetProperty("id").GetString()" />
                                    <select name="roleName" class="form-select form-select-sm" style="width: 140px;">
                                        <option value="StandartKullanici">Standart</option>
                                        <option value="OnOnayci">Ön Onaycı</option>
                                        <option value="KomisyonUyesi">Komisyon Üyesi</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm" title="Rol Güncelle"><i class="bi bi-arrow-repeat"></i></button>
                                </form>

                                <!-- Aktif/Pasif Durum Değiştirme Formu -->
                                <form asp-action="DurumDegistir" method="post">
                                    <input type="hidden" name="userId" value="@user.GetProperty("id").GetString()" />
                                    @if (isAktif)
                                    {
                                        <button type="submit" class="btn btn-warning btn-sm" title="Pasife Al"><i class="bi bi-pause-circle"></i> Pasif Yap</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-success btn-sm" title="Aktifleştir"><i class="bi bi-play-circle"></i> Aktif Yap</button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Yeni Kullanıcı Ekleme Modalı -->
<div class="modal fade" id="yeniKullaniciModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Yeni Kullanıcı Oluştur</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="KullaniciOlustur" method="post">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Ad</label>
                            <input name="Ad" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Soyad</label>
                            <input name="Soyad" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">E-posta</label>
                        <input name="Email" type="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Geçici Parola</label>
                        <input name="Parola" type="text" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Kullanıcı Rolü</label>
                        <select name="Rol" class="form-select">
                            <option value="StandartKullanici">Standart Kullanıcı</option>
                            <option value="OnOnayci">Ön Onaycı</option>
                            <option value="KomisyonUyesi">Komisyon Üyesi</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success">Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>