@model List<System.Text.Json.JsonElement>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    ViewData["PageTitle"] = "Kullanıcı Yönetimi";
}

@if (TempData["HataMesaji"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" style="font-size:12.5px; border-radius:6px;" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["HataMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-people me-2" style="color:#9ca3af;"></i>Kullanıcılar
        </span>
        <button type="button"
                class="btn-table"
                data-bs-toggle="modal"
                data-bs-target="#yeniKullaniciModal"
                style="color:#15803d; border-color:#d1fae5; background:#f0fdf4;">
            <i class="bi bi-person-plus me-1"></i>Yeni Kullanıcı
        </button>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th style="width:80px;">Durum</th>
                <th style="width:120px;">Rol</th>
                <th style="width:260px; text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var isAktif = user.GetProperty("aktifMi").GetBoolean();
                var userId = user.GetProperty("id").GetString();
                var adSoyad = user.GetProperty("ad").GetString() + " " + user.GetProperty("soyad").GetString();
                var email = user.GetProperty("email").GetString();
                var roller = string.Join(", ", user.GetProperty("roller").EnumerateArray().Select(r => r.GetString()));

                <tr>
                    <td>
                        <div style="display:flex; align-items:center; gap:9px;">
                            <div style="width:28px; height:28px; border-radius:6px; background:#0f1117; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:800; color:#fff; flex-shrink:0;">
                                @(adSoyad.Length >= 2 ? adSoyad.Substring(0, 2).ToUpper() : adSoyad.ToUpper())
                            </div>
                            <span class="td-primary">@adSoyad</span>
                        </div>
                    </td>
                    <td class="td-muted">@email</td>
                    <td>
                        @if (isAktif)
                        {
                            <span class="badge badge-kom-onaylı">Aktif</span>
                        }
                        else
                        {
                            <span class="badge badge-taslak">Pasif</span>
                        }
                    </td>
                    <td>
                        <span class="badge badge-on-bekliyor">@roller</span>
                    </td>
                    <td style="text-align:right;">
                        <div style="display:flex; gap:6px; justify-content:flex-end; align-items:center;">

                            @* Rol güncelleme *@
                            <form asp-action="RolGuncelle" method="post"
                                  style="display:flex; gap:5px; align-items:center;">
                                <input type="hidden" name="userId" value="@userId" />
                                <select name="roleName"
                                        class="form-control form-select"
                                        style="width:130px; font-size:11.5px; padding:4px 8px; height:30px;">
                                    <option value="StandartKullanici">Standart</option>
                                    <option value="OnOnayci">Ön Onaycı</option>
                                    <option value="KomisyonUyesi">Komisyon Üyesi</option>
                                    <option value="Admin">Admin</option>
                                </select>
                                <button type="submit"
                                        class="btn-table"
                                        style="padding:4px 9px;"
                                        title="Rolü güncelle">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </form>

                            @* Aktif/Pasif *@
                            <form asp-action="DurumDegistir" method="post">
                                <input type="hidden" name="userId" value="@userId" />
                                @if (isAktif)
                                {
                                    <button type="submit"
                                            class="btn-table"
                                            style="color:#b45309; border-color:#fde68a; background:#fffbeb;"
                                            title="Pasife al">
                                        <i class="bi bi-pause-circle me-1"></i>Pasif Yap
                                    </button>
                                }
                                else
                                {
                                    <button type="submit"
                                            class="btn-table"
                                            style="color:#15803d; border-color:#d1fae5; background:#f0fdf4;"
                                            title="Aktifleştir">
                                        <i class="bi bi-play-circle me-1"></i>Aktif Yap
                                    </button>
                                }
                            </form>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* Yeni kullanıcı modal *@
<div class="modal fade" id="yeniKullaniciModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog" style="max-width:460px;">
        <div class="modal-content" style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
            <form asp-action="KullaniciOlustur" method="post">

                <div style="padding:16px 20px; border-bottom:1px solid #f0f0f0; display:flex; align-items:center; justify-content:space-between;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="width:32px; height:32px; border-radius:7px; background:#f0fdf4; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-person-plus" style="color:#15803d; font-size:15px;"></i>
                        </div>
                        <div style="font-size:13px; font-weight:700; color:#111827;">Yeni Kullanıcı Oluştur</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size:12px;"></button>
                </div>

                <div style="padding:18px 20px; display:flex; flex-direction:column; gap:14px;">

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                        <div>
                            <label class="form-label">Ad</label>
                            <input name="Ad" class="form-control" required placeholder="Ahmet" />
                        </div>
                        <div>
                            <label class="form-label">Soyad</label>
                            <input name="Soyad" class="form-control" required placeholder="Kaya" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label">E-posta</label>
                        <input name="Email" type="email" class="form-control" required placeholder="ornek@sirket.com" />
                    </div>

                    <div>
                        <label class="form-label">
                            Geçici Parola
                            <span class="hint">— kullanıcı giriş sonrası değiştirebilir</span>
                        </label>
                        <input name="Parola" type="text" class="form-control" required placeholder="Geçici123!" />
                    </div>

                    <div>
                        <label class="form-label">Kullanıcı Rolü</label>
                        <select name="Rol" class="form-control form-select">
                            <option value="StandartKullanici">Standart Kullanıcı</option>
                            <option value="OnOnayci">Ön Onaycı</option>
                            <option value="KomisyonUyesi">Komisyon Üyesi</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                </div>

                <div style="padding:12px 20px; border-top:1px solid #f0f0f0; display:flex; justify-content:flex-end; gap:8px; background:#fafafa;">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                        İptal
                    </button>
                    <button type="submit"
                            class="btn btn-sm"
                            style="background:#0f1117; border-color:#0f1117; color:#fff; font-size:12px; padding:5px 14px; border-radius:6px; font-weight:600;">
                        <i class="bi bi-check me-1"></i>Kullanıcı Oluştur
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>