@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Tüm Fikirler (Admin)";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-lightbulb-fill me-2"></i>Tüm Fikirler ve Yönetim Paneli</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Başlık</th>
                    <th>Başvuru Sahibi</th>
                    <th>Durum</th>
                    <th class="text-end">Sistem İşlemleri</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fikir in Model)
                {
                    <tr>
                        <td>#@fikir.Id</td>
                        <td class="fw-bold">@fikir.Baslik</td>
                        <td>@fikir.BasvuruSahibiAdSoyad</td>
                        <td><span class="badge bg-secondary">@fikir.Durum</span></td>
                        <td class="text-end">
                            <a asp-action="IdeaMonitoring" asp-route-id="@fikir.Id" class="btn btn-sm btn-dark text-white" title="Sistem İzleme / Loglar">
                                <i class="bi bi-activity"></i> İzleme
                            </a>
                            <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#overrideModal-@fikir.Id" title="Sürece Müdahale Et">
                                <i class="bi bi-shield-exclamation"></i> Override
                            </button>
                        </td>
                    </tr>

                   
                    <div class="modal fade" id="overrideModal-@fikir.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content border-0">
                                <form asp-action="OverrideDurum" method="post">
                                    <div class="modal-header bg-warning">
                                        <h5 class="modal-title text-dark fw-bold">Manuel Müdahale (Fikir #@fikir.Id)</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body text-start">
                                        <div class="alert alert-danger small">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Sistem otomasyonunu bypass ediyorsunuz. Bu işlem güvenlik politikası gereği kalıcı olarak loglanacaktır.
                                        </div>
                                        <input type="hidden" name="FikirId" value="@fikir.Id" />

                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-dark">Hedef Durum</label>
                                            <select name="YeniDurum" class="form-select border-dark" required>
                                                <option value="1">Taslak</option>
                                                <option value="2">Ön Onay Bekliyor</option>
                                                <option value="3">Komisyon Onayı Bekliyor</option>
                                                <option value="4">Ön Onay Retli</option>
                                                <option value="5">Komisyon Onayı Retli</option>
                                                <option value="6">Komisyon Onaylı</option>
                                            </select>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-dark">Müdahale Gerekçesi (Audit Log)</label>
                                            <textarea name="Aciklama" class="form-control border-dark" rows="3" required placeholder="Gerekçenizi detaylı şekilde yazın..."></textarea>
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                        <button type="submit" class="btn btn-danger">Müdahaleyi Kaydet</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>