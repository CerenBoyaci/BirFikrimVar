@model List<BirFikrimVar.Web.Models.FikirListeViewModel>

@{
    ViewData["Title"] = "Tüm Fikirler";
    ViewData["PageTitle"] = "Tüm Fikirler";
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-inboxes me-2" style="color:#9ca3af;"></i>Tüm Fikirler
        </span>
        <span style="font-size:11.5px; color:#9ca3af; font-weight:500;">
            @Model.Count kayıt
        </span>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th style="width:60px;">ID</th>
                <th>Başlık</th>
                <th>Başvuru Sahibi</th>
                <th>Durum</th>
                <th style="width:160px; text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fikir in Model)
            {
                var badgeClass = fikir.Durum switch
                {
                    "Taslak" => "badge-taslak",
                    "ÖnOnayBekliyor" => "badge-on-bekliyor",
                    "ÖnOnayRetli" => "badge-on-retli",
                    "KomisyonOnayıBekliyor" => "badge-kom-bekliyor",
                    "KomisyonOnaylı" => "badge-kom-onaylı",
                    "KomisyonOnayıRetli" => "badge-kom-retli",
                    _ => "badge-taslak"
                };

                var badgeLabel = fikir.Durum switch
                {
                    "Taslak" => "Taslak",
                    "ÖnOnayBekliyor" => "Ön Onay Bekliyor",
                    "ÖnOnayRetli" => "Ön Onay Retli",
                    "KomisyonOnayıBekliyor" => "Komisyon Bekliyor",
                    "KomisyonOnaylı" => "Komisyon Onaylı",
                    "KomisyonOnayıRetli" => "Komisyon Retli",
                    _ => fikir.Durum
                };

                <tr>
                    <td class="td-muted" style="font-variant-numeric:tabular-nums;">#@fikir.Id</td>
                    <td class="td-primary">@fikir.Baslik</td>
                    <td class="td-muted">@fikir.BasvuruSahibiAdSoyad</td>
                    <td><span class="badge @badgeClass">@badgeLabel</span></td>
                    <td style="text-align:right;">
                        <div style="display:flex; gap:6px; justify-content:flex-end;">
                            <a asp-action="IdeaMonitoring"
                               asp-route-id="@fikir.Id"
                               class="btn-table"
                               title="Sistem logları">
                                <i class="bi bi-activity me-1"></i>İzleme
                            </a>
                            <button type="button"
                                    class="btn-table"
                                    data-bs-toggle="modal"
                                    data-bs-target="#overrideModal-@fikir.Id"
                                    style="color:#b45309; border-color:#fde68a; background:#fffbeb;">
                                <i class="bi bi-shield-exclamation me-1"></i>Override
                            </button>
                        </div>
                    </td>
                </tr>

                <div class="modal fade" id="overrideModal-@fikir.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog" style="max-width:460px;">
                        <div class="modal-content" style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
                            <form asp-action="OverrideDurum" method="post">
                                <div style="padding:16px 20px; border-bottom:1px solid #f0f0f0; display:flex; align-items:center; justify-content:space-between;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <div style="width:32px; height:32px; border-radius:7px; background:#fff7ed; display:flex; align-items:center; justify-content:center;">
                                            <i class="bi bi-shield-exclamation" style="color:#f97316; font-size:15px;"></i>
                                        </div>
                                        <div>
                                            <div style="font-size:13px; font-weight:700; color:#111827;">Manuel Müdahale</div>
                                            <div style="font-size:11px; color:#9ca3af;">Fikir #@fikir.Id</div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size:12px;"></button>
                                </div>

                                <div style="padding:18px 20px;">
                                    <div style="background:#fef2f2; border:1px solid #fee2e2; border-radius:6px; padding:10px 12px; margin-bottom:16px; display:flex; gap:8px; align-items:flex-start;">
                                        <i class="bi bi-exclamation-triangle" style="color:#ef4444; font-size:13px; margin-top:1px; flex-shrink:0;"></i>
                                        <span style="font-size:11.5px; color:#b91c1c; line-height:1.5;">
                                            Sistem otomasyonunu bypass ediyorsunuz. Bu işlem güvenlik politikası gereği kalıcı olarak loglanacaktır.
                                        </span>
                                    </div>

                                    <input type="hidden" name="FikirId" value="@fikir.Id" />

                                    <div class="mb-3">
                                        <label class="form-label">Hedef Durum</label>
                                        <select name="YeniDurum" class="form-control form-select" required>
                                            <option value="1">Taslak</option>
                                            <option value="2">Ön Onay Bekliyor</option>
                                            <option value="3">Komisyon Onayı Bekliyor</option>
                                            <option value="4">Ön Onay Retli</option>
                                            <option value="5">Komisyon Onayı Retli</option>
                                            <option value="6">Komisyon Onaylı</option>
                                        </select>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label">
                                            Müdahale Gerekçesi
                                            <span class="hint">— Audit log'a yazılacak</span>
                                        </label>
                                        <textarea name="Aciklama"
                                                  class="form-control"
                                                  rows="3"
                                                  required
                                                  placeholder="Gerekçenizi detaylı şekilde yazın..."></textarea>
                                    </div>
                                </div>

                                <div style="padding:12px 20px; border-top:1px solid #f0f0f0; display:flex; justify-content:flex-end; gap:8px; background:#fafafa;">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                                        İptal
                                    </button>
                                    <button type="submit"
                                            class="btn btn-sm"
                                            style="background:#dc2626; border-color:#dc2626; color:#fff; font-size:12px; padding:5px 14px; border-radius:6px; font-weight:600;">
                                        <i class="bi bi-shield-exclamation me-1"></i>Müdahaleyi Kaydet
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>