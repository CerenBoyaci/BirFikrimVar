@model List<BirFikrimVar.Web.Models.KategoriViewModel>

@{
    ViewData["Title"] = "Puanlama Kategorileri";
}

<div class="row">
 
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-tags-fill me-2"></i>Mevcut Kategoriler</h5>
            </div>
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Kategori Adı</th>
                            <th>Durum</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kat in Model)
                        {
                            <tr>
                                <td>@kat.Id</td>
                                <td class="fw-bold">@kat.Ad</td>
                                <td>
                                    @if (kat.AktifMi)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <!-- Düzenle Modalı Tetikleyici -->
                                    <button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal" data-bs-target="#editModal-@kat.Id" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </button>

                                    <!-- Tek Tıkla Durum Değiştirme (Aktif <-> Pasif) -->
                                    <form asp-action="KaydetKategori" method="post" class="d-inline">
                                        <input type="hidden" name="Id" value="@kat.Id" />
                                        <input type="hidden" name="Ad" value="@kat.Ad" />
                                        <input type="hidden" name="AktifMi" value="@(kat.AktifMi ? "false" : "true")" />

                                        <button type="submit" class="btn btn-sm @(kat.AktifMi ? "btn-danger" : "btn-success")" title="@(kat.AktifMi ? "Pasife Al" : "Aktifleştir")">
                                            <i class="bi @(kat.AktifMi ? "bi-x-circle" : "bi-check-circle")"></i> @(kat.AktifMi ? "Pasife Al" : "Aktifleştir")
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            <!-- Düzenleme Modalı -->
                            <div class="modal fade" id="editModal-@kat.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content border-0">
                                        <form asp-action="KaydetKategori" method="post">
                                            <div class="modal-header bg-light">
                                                <h5 class="modal-title text-dark fw-bold">Kategori Düzenle (#@kat.Id)</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body text-start">
                                                <input type="hidden" name="Id" value="@kat.Id" />

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Kategori Adı</label>
                                                    <input type="text" name="Ad" class="form-control" value="@kat.Ad" required />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Durum</label>
                                                    <select name="AktifMi" class="form-select">
                                                        @if (kat.AktifMi)
                                                        {
                                                            <option value="true" selected>Aktif (Değerlendirmede Görünür)</option>
                                                            <option value="false">Pasif (Gizli)</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="true">Aktif (Değerlendirmede Görünür)</option>
                                                            <option value="false" selected>Pasif (Gizli)</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="modal-footer bg-light">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Değişiklikleri Kaydet</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

   
    <div class="col-md-4">
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 text-primary"><i class="bi bi-plus-circle me-2"></i>Yeni Kategori Ekle</h5>
            </div>
            <div class="card-body">
                <form asp-action="KaydetKategori" method="post">
                    <input type="hidden" name="Id" value="0" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kategori Adı</label>
                        <input type="text" name="Ad" class="form-control" required placeholder="Örn: Stratejik Uyum" />
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="AktifMi" value="true" checked>
                        <label class="form-check-label fw-bold">Aktif Olarak Başlat</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>