@model List<System.Text.Json.JsonElement>

@{
    ViewData["Title"] = "Sistem İşlem Logları";
    ViewData["PageTitle"] = "Sistem İşlem Logları";
}

@if (TempData["HataMesaji"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" style="font-size:12.5px; border-radius:6px;" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["HataMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-clock-history me-2" style="color:#9ca3af;"></i>Güvenlik ve İşlem Logları
        </span>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th style="width:160px;">Tarih</th>
                    <th style="width:250px;">İşlem Yapan</th>
                    <th style="width:180px;">İşlem Tipi</th>
                    <th>Açıklama / Detay</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    var islemTarihi = log.GetProperty("islemTarihi").GetDateTime().ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss");
                    var adminAdSoyad = log.GetProperty("adminAdSoyad").GetString() ?? "Bilinmeyen";
                    var islemTipi = log.GetProperty("islemTipi").GetString();
                    var aciklama = log.GetProperty("aciklama").GetString();

                    <tr>
                        <td class="td-muted" style="font-family:monospace; font-size:12.5px;">@islemTarihi</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:9px;">
                                <div style="width:28px; height:28px; border-radius:6px; background:#0f1117; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:800; color:#fff; flex-shrink:0;">
                                    @(adminAdSoyad.Length >= 2 ? adminAdSoyad.Substring(0, 2).ToUpper() : "AD")
                                </div>
                                <span class="td-primary">@adminAdSoyad</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge badge-on-bekliyor">@islemTipi</span>
                        </td>
                        <td class="td-muted">@aciklama</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:40px 20px; text-align:center; color:#6b7280; font-size:13px;">
            <i class="bi bi-inbox mb-2" style="font-size:26px; display:block; color:#d1d5db;"></i>
            Henüz sisteme kaydedilmiş bir admin işlemi bulunmamaktadır.
        </div>
    }
</div>